<?xml version="1.0" encoding="utf-8" ?>
<Page x:ConnectionId='1'
    x:Class="PMTool.App.Views.Projects.ProjectListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Views.Projects"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:Name="ProjectPageRoot"
                                      
    Background="{StaticResource AloneSurfaceBrush}"
    mc:Ignorable="d">
    <Grid Padding="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="{StaticResource Spacing4}">
                <ItemsControl x:ConnectionId='8'                                                       >
                    <ItemsControl.ItemTemplate>
                        <DataTemplate                                    >
                            <Button x:ConnectionId='10'
                                Padding="0"
                                Margin="0,0,0,16"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding ElementName=ProjectPageRoot, Path=ViewModel.SelectProjectCommand}"
                                                           
                                CornerRadius="{StaticResource DefaultCornerRadius}">
                                <Border
                                    Padding="16"
                                    HorizontalAlignment="Stretch"
                                    Background="{StaticResource AloneSurfaceContainerLowestBrush}"
                                    CornerRadius="{StaticResource DefaultCornerRadius}">
                                    <StackPanel Spacing="6">
                                        <TextBlock x:ConnectionId='11' Style="{StaticResource AloneTitleSmTextBlockStyle}"                                   />
                                        <TextBlock x:ConnectionId='12'
                                            Opacity="0.85"
                                            Style="{StaticResource AloneLabelMdTextBlockStyle}"
                                                                                />
                                        <TextBlock x:ConnectionId='13'
                                            Opacity="0.9"
                                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                                                     />
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border x:ConnectionId='2'
            x:Name="DetailPanel"
            Grid.Column="1"
            Margin="24,0,0,0"
            Padding="16"
            Width="{StaticResource DetailPanelWidth}"
            HorizontalAlignment="Stretch"
            Background="{StaticResource AloneSurfaceContainerLowestBrush}"
            CornerRadius="{StaticResource DefaultCornerRadius}"
                                                                              >
            <StackPanel Spacing="12">
                <TextBlock x:ConnectionId='3' Style="{StaticResource AloneTitleLgTextBlockStyle}"                                                    />
                <TextBlock x:ConnectionId='4' Style="{StaticResource AloneLabelMdTextBlockStyle}"                                                     />
                <TextBlock x:ConnectionId='5'
                    TextWrapping="WrapWholeWords"
                    Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                                      />
                <TextBlock x:ConnectionId='6' Style="{StaticResource AloneBodyMdTextBlockStyle}"                                                    />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="编辑" Style="{StaticResource AloneSecondaryButtonStyle}" />
                    <Button Content="归档" Style="{StaticResource AloneSecondaryButtonStyle}" />
                    <Button Content="删除" Style="{StaticResource AloneSecondaryButtonStyle}" />
                </StackPanel>
                <Button x:ConnectionId='7'
                    HorizontalAlignment="Stretch"
                                                                                   
                    Content="关闭详情"
                    Style="{StaticResource AloneSecondaryButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>

