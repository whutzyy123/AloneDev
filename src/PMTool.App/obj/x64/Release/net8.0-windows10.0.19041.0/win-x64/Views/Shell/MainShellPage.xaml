<?xml version="1.0" encoding="utf-8" ?>
<Page x:ConnectionId='1'
    x:Class="PMTool.App.Views.Shell.MainShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Views.Shell"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:PMTool.App.Controls"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:Name="ShellRoot"
                                    
    Background="{StaticResource AloneSurfaceBrush}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource NavRailWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left rail -->
        <Grid
            Grid.Column="0"
            Padding="0,16,0,16"
            Background="{StaticResource AloneSurfaceContainerLowBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Padding="16,0,16,16"
                Spacing="12">
                <Button
                    Width="40"
                    Height="40"
                    HorizontalAlignment="Left"
                    Padding="0"
                    Background="{StaticResource AloneSurfaceContainerHighestBrush}"
                    BorderThickness="0"
                    CornerRadius="20"
                    ToolTipService.ToolTip="账号（占位）">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE77B;" />
                </Button>
                <Button x:ConnectionId='18'
                    x:Name="OpenSearchButton"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    BorderThickness="0"
                    CornerRadius="{StaticResource DefaultCornerRadius}"
                    Style="{StaticResource AloneSecondaryButtonStyle}"
                    ToolTipService.ToolTip="全局搜索">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE721;" />
                        <TextBlock Style="{StaticResource AloneBodyMdTextBlockStyle}" Text="搜索" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:ConnectionId='11'                                                                >
                    <ItemsControl.ItemTemplate>
                        <DataTemplate                                  >
                            <Button x:ConnectionId='13'
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="0"
                                Command="{Binding ElementName=ShellRoot, Path=ViewModel.SelectNavCommand}"
                                                           >
                                <Grid Padding="12,10,16,10">
                                    <Border x:ConnectionId='14'
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Background="{StaticResource AloneSurfaceContainerHighestBrush}"
                                                                                            />
                                    <Grid ColumnSpacing="12" ColumnDefinitions="Auto,*">
                                        <Rectangle x:ConnectionId='15'
                                            Width="4"
                                            Margin="-12,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Stretch"
                                            Fill="{StaticResource AlonePrimaryBrush}"
                                            RadiusX="2"
                                            RadiusY="2"
                                                                                          />
                                        <StackPanel
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="12">
                                            <SymbolIcon x:ConnectionId='16' VerticalAlignment="Center"                                      />
                                            <TextBlock x:ConnectionId='17'
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                                                   />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel
                Grid.Row="2"
                Padding="0,16,0,0"
                Background="{StaticResource AloneSurfaceContainerLowBrush}">
                <ItemsControl x:ConnectionId='4'                                                               >
                    <ItemsControl.ItemTemplate>
                        <DataTemplate                                  >
                            <Button x:ConnectionId='6'
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="0"
                                Command="{Binding ElementName=ShellRoot, Path=ViewModel.SelectNavCommand}"
                                                           >
                                <Grid Padding="12,10,16,10">
                                    <Border x:ConnectionId='7'
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Background="{StaticResource AloneSurfaceContainerHighestBrush}"
                                                                                            />
                                    <Grid ColumnSpacing="12" ColumnDefinitions="Auto,*">
                                        <Rectangle x:ConnectionId='8'
                                            Width="4"
                                            Margin="-12,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Stretch"
                                            Fill="{StaticResource AlonePrimaryBrush}"
                                            RadiusX="2"
                                            RadiusY="2"
                                                                                          />
                                        <StackPanel
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="12">
                                            <SymbolIcon x:ConnectionId='9' VerticalAlignment="Center"                                      />
                                            <TextBlock x:ConnectionId='10'
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                                                   />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <!-- Main column -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="{StaticResource OperationBarHeight}" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:OperationBar x:ConnectionId='2'
                Grid.Row="0"
                                                                    />

            <Frame x:ConnectionId='3' x:Name="ContentFrame" Grid.Row="1" />
        </Grid>
    </Grid>
</Page>

