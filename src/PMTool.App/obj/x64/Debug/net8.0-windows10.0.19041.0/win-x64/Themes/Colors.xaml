<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <!-- 画布 #F5F7FA；白卡 AloneSurfaceContainerLowest；Low/High 为中性灰阶（弱化整屏浅蓝灰糊在一起） -->
            <SolidColorBrush x:Key="AloneSurfaceBrush" Color="#F5F7FA" />
            <SolidColorBrush x:Key="AloneSurfaceContainerLowBrush" Color="#E8EBF1" />
            <SolidColorBrush x:Key="AloneSurfaceContainerLowestBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="AloneChromeElevatedBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="AloneSurfaceContainerHighBrush" Color="#DDE1E8" />
            <SolidColorBrush x:Key="AloneSurfaceContainerHighestBrush" Color="#CED4DC" />
            <SolidColorBrush x:Key="AloneSearchChromeBrush" Color="#66FFFFFF" />
            <SolidColorBrush x:Key="AloneNavRailActiveBrush" Color="#D0E4F7" />
            <SolidColorBrush x:Key="AlonePrimaryBrush" Color="#006CBE" />
            <SolidColorBrush x:Key="AlonePrimaryContainerBrush" Color="#004A83" />
            <SolidColorBrush x:Key="AloneOnSurfaceBrush" Color="#181c22" />
            <SolidColorBrush x:Key="AloneOnSurfaceVariantBrush" Color="#404752" />
            <SolidColorBrush x:Key="AloneSectionHeadingBrush" Color="#2B3340" />
            <SolidColorBrush x:Key="AloneOnPrimaryBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="AloneSecondaryContainerBrush" Color="#8EBAF0" />
            <SolidColorBrush x:Key="AloneNavHoverBrush" Color="#006CBE" Opacity="0.12" />
            <SolidColorBrush x:Key="AloneOnSurfaceDisabledBrush" Color="#181c22" Opacity="0.38" />
            <SolidColorBrush x:Key="AloneSuccessBrush" Color="#107C10" />
            <SolidColorBrush x:Key="AloneWarningBrush" Color="#CA5010" />
            <SolidColorBrush x:Key="AloneErrorBrush" Color="#C42B1C" />
            <SolidColorBrush x:Key="AloneInfoBrush" Color="#006CBE" />
            <SolidColorBrush x:Key="SearchRowHighlightBrush" Color="#D9ECFA" />
            <!-- 卡片浅描边（Light）；与下拉选中态同系浅蓝灰 -->
            <SolidColorBrush x:Key="AloneCardOutlineBrush" Color="#EFF2F5" />
            <!-- 项目状态胶囊 -->
            <SolidColorBrush x:Key="AloneChipProjectActiveBackgroundBrush" Color="#B2EBF2" />
            <SolidColorBrush x:Key="AloneChipProjectActiveForegroundBrush" Color="#006978" />
            <SolidColorBrush x:Key="AloneChipProjectMutedBackgroundBrush" Color="#E4E7EE" />
            <!-- 开发者语义：任务类型色条（低饱和） -->
            <SolidColorBrush x:Key="AloneDevAccentBugBrush" Color="#C25C5E" />
            <LinearGradientBrush x:Key="AloneDevAccentBugBrushGradient" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#D07072" />
                <GradientStop Offset="1" Color="#A8484A" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AloneDevAccentRefactorBrush" Color="#7E6BA8" />
            <SolidColorBrush x:Key="AloneDevAccentResearchBrush" Color="#3D5F78" />
            <SolidColorBrush x:Key="AloneDevAccentFeatureBrush" Color="#006CBE" />
            <!-- 看板列：极浅槽底 + 列顶细条用 AloneKanbanColumnAccent* -->
            <SolidColorBrush x:Key="AloneKanbanColumnBackgroundBrush" Color="#F9FAFB" />
            <SolidColorBrush x:Key="AloneKanbanColumnBrush0" Color="#F9FAFB" />
            <SolidColorBrush x:Key="AloneKanbanColumnBrush1" Color="#F9FAFB" />
            <SolidColorBrush x:Key="AloneKanbanColumnBrush2" Color="#F9FAFB" />
            <SolidColorBrush x:Key="AloneKanbanColumnBrush3" Color="#F9FAFB" />
            <SolidColorBrush x:Key="AloneKanbanColumnAccent0" Color="#8A93A3" />
            <SolidColorBrush x:Key="AloneKanbanColumnAccent1" Color="#006CBE" />
            <SolidColorBrush x:Key="AloneKanbanColumnAccent2" Color="#107C10" />
            <SolidColorBrush x:Key="AloneKanbanColumnAccent3" Color="#6B5B95" />
            <SolidColorBrush x:Key="AloneKanbanDropTargetBrush" Color="#006CBE" Opacity="0.14" />
            <LinearGradientBrush x:Key="AlonePrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#004578" />
                <GradientStop Offset="0.55" Color="#005A9E" />
                <GradientStop Offset="1" Color="#0078D4" />
            </LinearGradientBrush>
            <!-- 侧栏选中：浅渐变叠加（约 10% 视感） -->
            <LinearGradientBrush x:Key="AloneNavRailActiveOverlayBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Offset="0" Color="#22006CBE" />
                <GradientStop Offset="1" Color="#0D006CBE" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AloneChipPriorityP0BackgroundBrush" Color="#F5D4D6" />
            <SolidColorBrush x:Key="AloneChipPriorityP0ForegroundBrush" Color="#8B292F" />
            <!-- 项目卡片封面条：由 ProjectId 稳定映射，色相错开 -->
            <LinearGradientBrush x:Key="AloneProjectCoverGradient0" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#005A9E" />
                <GradientStop Offset="1" Color="#47A7FF" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AloneProjectCoverGradient1" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#0B6B6B" />
                <GradientStop Offset="1" Color="#3EB8B8" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AloneProjectCoverGradient2" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#5C3D8C" />
                <GradientStop Offset="1" Color="#9B7FD8" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AloneProjectCoverGradient3" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#2E6B3A" />
                <GradientStop Offset="1" Color="#6CCB7A" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AloneProjectCoverGradient4" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#A64F1C" />
                <GradientStop Offset="1" Color="#E8A050" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AloneProjectCoverGradient5" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#3D4F6B" />
                <GradientStop Offset="1" Color="#7A8FB0" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AloneProjectCoverGradient6" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#8B2F4A" />
                <GradientStop Offset="1" Color="#D87892" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AloneProjectCoverGradient7" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#303D7A" />
                <GradientStop Offset="1" Color="#6B7FD4" />
            </LinearGradientBrush>
            <!-- 代码片段 WebView：固定深色壳，与 atom-one-dark 基底一致 -->
            <SolidColorBrush x:Key="AloneCodePreviewHostBrush" Color="#282C34" />
            <!-- 表单 ToggleSwitch「开」态：覆盖 Fluent 默认 Accent，统一为品牌蓝 -->
            <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#006CBE" />
            <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#005A9E" />
            <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#004A83" />
            <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="#006CBE" />
            <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="#005A9E" />
            <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed" Color="#004A83" />
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPointerOver" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPressed" Color="#FFFFFF" />
            <!-- Fluent List/Combo 选中浅底：覆盖系统强调紫，统一品牌浅蓝 -->
            <SolidColorBrush x:Key="SystemControlHighlightListAccentLowBrush" Color="#D9ECFA" />
            <SolidColorBrush x:Key="SystemControlHighlightListAccentMediumBrush" Color="#B8DCF4" />
            <SolidColorBrush x:Key="SystemControlHighlightListLowBrush" Color="#EBF4FB" />
            <!-- Fluent Accent：锁定为品牌蓝，避免跟随 Windows 个性化强调色（按钮/AccentButtonStyle 等模板） -->
            <Color x:Key="SystemAccentColor">#FF006CBE</Color>
            <Color x:Key="SystemAccentColorLight1">#FF1080D8</Color>
            <Color x:Key="SystemAccentColorLight2">#FF2B8FD8</Color>
            <Color x:Key="SystemAccentColorLight3">#FF47A7FF</Color>
            <Color x:Key="SystemAccentColorDark1">#FF005A9E</Color>
            <Color x:Key="SystemAccentColorDark2">#FF004A83</Color>
            <Color x:Key="SystemAccentColorDark3">#FF003D6B</Color>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#006CBE" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#0078D4" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#004A83" />
            <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="#006CBE" Opacity="0.35" />
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#FFFFFF" Opacity="0.85" />
            <SolidColorBrush x:Key="AccentTextFillColorDisabledBrush" Color="#FFFFFF" Opacity="0.38" />
            <!-- 对话框次要按钮浅底（约 5% 品牌蓝） -->
            <SolidColorBrush x:Key="AloneDialogSecondaryFillBrush" Color="#0D006CBE" />
            <!-- 全局 TextBox：聚焦描边与品牌一致（非对话框页亦生效） -->
            <SolidColorBrush x:Key="TextControlBorderBrush" Color="#CED4DC" />
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#B8BFC8" />
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#006CBE" />
            <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="#E8EBF1" />
        </ResourceDictionary>
