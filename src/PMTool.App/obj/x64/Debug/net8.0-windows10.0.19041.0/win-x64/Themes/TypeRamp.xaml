<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="DisplayMdFontSize">44</x:Double>
    <x:Double x:Key="HeadlineSmFontSize">24</x:Double>
    <x:Double x:Key="AlonePageTitleFontSize">26</x:Double>
    <x:Double x:Key="AlonePageTitleLineHeight">32</x:Double>
    <x:Double x:Key="TitleSmFontSize">16</x:Double>
    <x:Double x:Key="BodyMdFontSize">14</x:Double>
    <x:Double x:Key="LabelMdFontSize">12</x:Double>
    <x:Double x:Key="CaptionFontSize">11</x:Double>

    <Style x:Key="AloneDisplayMdTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource DisplayMdFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceBrush}" />
    </Style>

    <Style x:Key="AloneHeadlineSmTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource HeadlineSmFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-18" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceBrush}" />
    </Style>

    <!-- 操作栏 / 模块主标题：24–28 档内加粗，层级高于列表卡片标题 -->
    <Style x:Key="AlonePageTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource AlonePageTitleFontSize}" />
        <Setter Property="LineHeight" Value="{StaticResource AlonePageTitleLineHeight}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="-18" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceBrush}" />
    </Style>

    <!-- 模块统计、列表卡片灰字元信息：12px + OnSurfaceVariant -->
    <Style x:Key="AloneModuleMetaTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource LabelMdFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceVariantBrush}" />
    </Style>

    <Style x:Key="AloneTitleTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource AloneHeadlineSmTextBlockStyle}" />

    <Style x:Key="AloneTitleSmTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource TitleSmFontSize}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceBrush}" />
    </Style>

    <Style x:Key="AloneTitleLgTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource AloneTitleSmTextBlockStyle}">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="AloneSubtitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceVariantBrush}" />
    </Style>

    <Style x:Key="AloneBodyMdTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource BodyMdFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceBrush}" />
    </Style>

    <Style x:Key="AloneBodyTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource AloneBodyMdTextBlockStyle}" />

    <Style x:Key="AloneBodySecondaryTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource AloneBodyMdTextBlockStyle}">
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceVariantBrush}" />
    </Style>

    <Style x:Key="AloneLabelMdTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource LabelMdFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource AloneSectionHeadingBrush}" />
    </Style>

    <Style x:Key="AloneCaptionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource CaptionFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceVariantBrush}" />
    </Style>
</ResourceDictionary>

