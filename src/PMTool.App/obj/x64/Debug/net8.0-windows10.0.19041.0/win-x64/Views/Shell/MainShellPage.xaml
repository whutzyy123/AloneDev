<?xml version="1.0" encoding="utf-8" ?>
<Page x:ConnectionId='1'
    x:Class="PMTool.App.Views.Shell.MainShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Views.Shell"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:PMTool.App.Controls"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:Name="ShellRoot"
                                    
    Background="Transparent"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="NavRailItemTemplate"                                  >
            <Button x:ConnectionId='3'
                MinHeight="{StaticResource AloneNavItemHeight}"
                Padding="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                CornerRadius="{StaticResource DefaultCornerRadius}"
                Command="{Binding ElementName=ShellRoot, Path=ViewModel.SelectNavCommand}"
                                           
                                                                    >
                <Grid Padding="{StaticResource AloneNavItemPadding}">
                    <Border x:ConnectionId='4'
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="{ThemeResource AloneNavRailActiveOverlayBrush}"
                        CornerRadius="{StaticResource DefaultCornerRadius}"
                                                                            />
                    <Viewbox x:ConnectionId='5'
                        Width="{StaticResource AloneNavIconBox}"
                        Height="{StaticResource AloneNavIconBox}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                                                                                                                         >
                        <SymbolIcon x:ConnectionId='9'
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AloneOnSurfaceBrush}"
                            Opacity="0.92"
                                                                 />
                    </Viewbox>
                    <StackPanel x:ConnectionId='6'
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="{StaticResource AloneSpace16}"
                                                                                                                                >
                        <Viewbox
                            Width="{StaticResource AloneNavIconBox}"
                            Height="{StaticResource AloneNavIconBox}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                            <SymbolIcon x:ConnectionId='8'
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource AloneOnSurfaceBrush}"
                                Opacity="0.92"
                                                                     />
                        </Viewbox>
                        <TextBlock x:ConnectionId='7'
                            VerticalAlignment="Center"
                                                                                 
                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                               />
                    </StackPanel>
                </Grid>
            </Button>
        </DataTemplate>
    </Page.Resources>
    <Page.KeyboardAccelerators>
        <KeyboardAccelerator x:ConnectionId='10'
            Key="K"
                                                     
            Modifiers="Control" />
    </Page.KeyboardAccelerators>
    <Grid x:ConnectionId='11'
        x:Name="RootLayout"
                                                  >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 全宽自定义顶栏：系统按钮区在右侧保留空白列 -->
        <Grid x:ConnectionId='12'
            x:Name="TitleBarDragRegion"
            Grid.Row="0"
            MinHeight="{StaticResource ShellChromeBarHeight}">
            <Border Background="{ThemeResource AloneChromeElevatedBrush}" Shadow="{StaticResource AloneFloatThemeShadow}">
                <Grid Padding="{StaticResource AloneShellChromePadding}" ColumnSpacing="{StaticResource AloneSpace16}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{StaticResource ShellChromeCaptionRightInsetGrid}" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="12,0,8,0"
                        Spacing="2">
                        <TextBlock Style="{StaticResource AloneTitleSmTextBlockStyle}" Text="AloneDev" />
                        <TextBlock x:ConnectionId='30'
                            Style="{StaticResource AloneModuleMetaTextBlockStyle}"
                                                                               />
                    </StackPanel>
                    <Grid
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        ColumnSpacing="{StaticResource AloneSpace8}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:ConnectionId='28'
                            x:Name="SearchExpandButton"
                            Grid.Column="0"
                            Width="36"
                            Height="36"
                            Padding="0"
                            Background="{ThemeResource AloneSearchChromeBrush}"
                            BorderThickness="0"
                                                            
                            CornerRadius="{StaticResource AloneSearchPillCornerRadius}"
                            ToolTipService.ToolTip="搜索（Ctrl+K）">
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE721;" />
                        </Button>
                        <AutoSuggestBox x:ConnectionId='29'
                            x:Name="ShellGlobalSearchBox"
                            Grid.Column="1"
                            MinWidth="340"
                            MinHeight="36"
                            MaxWidth="760"
                            Width="680"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Opacity="0"
                            Background="{ThemeResource AloneSearchChromeBrush}"
                            BorderThickness="0"
                            CornerRadius="{StaticResource AloneSearchPillCornerRadius}"
                                                                    
                            PlaceholderText="搜索并跳转…（Ctrl+K）"
                            QueryIcon="Find"
                            RenderTransformOrigin="0.5,0.5"
                            Visibility="Collapsed"
                                                                                                                  >
                            <AutoSuggestBox.RenderTransform>
                                <ScaleTransform ScaleX="0.92" ScaleY="1" />
                            </AutoSuggestBox.RenderTransform>
                        </AutoSuggestBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource NavRailWidthGrid}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left rail：白底 + ThemeShadow，与画布分层 -->
            <Border
                Grid.Column="0"
                Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                Shadow="{StaticResource AloneFloatThemeShadow}">
                <Grid Padding="{StaticResource AloneNavRailOuterPadding}" Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Padding="{StaticResource AloneNavHeaderStackPadding}"
                Spacing="{StaticResource AloneSpace16}">
                <StackPanel Spacing="{StaticResource AloneSpace8}">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace16}">
                        <Border
                            Width="40"
                            Height="40"
                            VerticalAlignment="Center"
                            CornerRadius="{StaticResource CornerRadiusSmall}"
                            Background="{ThemeResource AlonePrimaryGradientBrush}">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="20"
                                Foreground="{ThemeResource AloneOnPrimaryBrush}"
                                Glyph="&#xE8F1;" />
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock
                                Style="{StaticResource AloneTitleLgTextBlockStyle}"
                                Text="AloneDev" />
                            <TextBlock
                                CharacterSpacing="80"
                                Style="{StaticResource AloneModuleMetaTextBlockStyle}"
                                Text="本地工作区 · 离线" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:ConnectionId='27' ItemTemplate="{StaticResource NavRailItemTemplate}"                                                                 />
            </ScrollViewer>

                <Border
                    Grid.Row="2"
                    Margin="12,8,12,8"
                    Padding="{StaticResource AlonePadding8}"
                    Background="{ThemeResource AloneSurfaceContainerLowBrush}"
                    CornerRadius="{StaticResource DefaultCornerRadius}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ItemsControl x:ConnectionId='16'
                            Grid.Row="0"
                            HorizontalAlignment="Stretch"
                            ItemTemplate="{StaticResource NavRailItemTemplate}"
                                                                                          >
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel
                                        HorizontalAlignment="Stretch"
                                        Orientation="Vertical"
                                        Spacing="{StaticResource AloneSpace16}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <Button x:ConnectionId='17'
                            x:Name="AccountMenuButton"
                            Grid.Row="1"
                            Width="40"
                            Height="40"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Left"
                            Padding="0"
                            Background="{ThemeResource AloneSurfaceContainerHighestBrush}"
                            BorderThickness="0"
                            CornerRadius="{StaticResource AloneSearchPillCornerRadius}"
                            ToolTipService.ToolTip="切换工作空间（本地数据隔离）">
                            <Button.Flyout>
                                <Flyout x:ConnectionId='18' FlyoutPresenterStyle="{StaticResource AloneFlyoutPresenterStyle}"                                >
                                    <StackPanel MinWidth="280" Spacing="{StaticResource AloneSpace16}">
                                        <TextBlock Style="{StaticResource AloneBodyMdTextBlockStyle}" Text="当前工作空间" />
                                        <TextBlock x:ConnectionId='19' Style="{StaticResource AloneBodyMdTextBlockStyle}"                                                              />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                            Text="工作空间列表" />
                                        <ListView x:ConnectionId='20'
                                            MaxHeight="200"
                                            Padding="{StaticResource AloneListViewInlayPadding}"
                                            Background="{ThemeResource AloneSurfaceContainerHighestBrush}"
                                            CornerRadius="{StaticResource DefaultCornerRadius}"
                                                                                                  
                                                                                                              
                                            SelectionMode="Single" />
                                        <TextBox x:ConnectionId='21'
                                            Header="新建工作空间名称"
                                            PlaceholderText="例如：个人项目、公司私活、学习练习"
                                            Style="{StaticResource AloneFormTextBoxStyle}"
                                                                                                                                       />
                                        <Button x:ConnectionId='22'
                                            HorizontalAlignment="Stretch"
                                                                                          
                                            Content="创建工作空间"
                                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                                        <Button x:ConnectionId='23'
                                            HorizontalAlignment="Stretch"
                                                                                             
                                            Content="切换到此工作空间"
                                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                                        <Button x:ConnectionId='24'
                                            HorizontalAlignment="Stretch"
                                                                             
                                            Content="删除此工作空间…"
                                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                                        <Button x:ConnectionId='25'
                                            HorizontalAlignment="Stretch"
                                                                                           
                                            Content="初始化环境"
                                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                                        <TextBlock x:ConnectionId='26'
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                                                
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE77B;" />
                        </Button>
                    </Grid>
                </Border>
                </Grid>
            </Border>

            <!-- Main column -->
            <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="{StaticResource OperationBarHeightGrid}" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:OperationBar x:ConnectionId='14'
                x:Name="MainOperationBar"
                Grid.Row="0"
                                                                   
                                                                                  />

            <Grid
                Grid.Row="1"
                Padding="{StaticResource AloneContentHostPadding}"
                Background="{ThemeResource AloneSurfaceBrush}">
                <!-- Frame 必须在本行获得明确垂直空间；外包 Center 的 Grid 会导致部分布局下 Frame 高度为 0，子页整片空白 -->
                <Border
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                    CornerRadius="{StaticResource DefaultCornerRadius}"
                    Shadow="{StaticResource AloneFloatThemeShadow}">
                    <Frame x:ConnectionId='15'
                        x:Name="ContentFrame"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch" />
                </Border>
            </Grid>
            </Grid>
        </Grid>

        <TeachingTip x:ConnectionId='13'
            x:Name="GlobalSearchShortcutTip"
            Grid.RowSpan="2"
            Title="全局搜索"
            Subtitle="使用顶栏搜索框或 Ctrl+K，在项目、模块、任务等内容间快速跳转。"
            PreferredPlacement="Right"
            IsLightDismissEnabled="True"
            ActionButtonContent="知道了"
                                                                         
                                                      />
    </Grid>
</Page>

