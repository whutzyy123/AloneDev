<?xml version="1.0" encoding="utf-8" ?>
<Page x:ConnectionId='1'
    x:Class="PMTool.App.Views.Projects.ProjectListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PMTool.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Views.Projects"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:Name="ProjectPageRoot"
                                      
    Background="{ThemeResource AloneSurfaceBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="ProjectRowCardTemplate"                                    >
            <Button x:ConnectionId='3'
                Padding="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding ElementName=ProjectPageRoot, Path=ViewModel.SelectProjectCommand}"
                                           
                CornerRadius="{StaticResource CornerRadiusLarge}">
                <Border x:ConnectionId='4'
                    HorizontalAlignment="Stretch"
                                                                                                                                 
                    CornerRadius="{StaticResource CornerRadiusLarge}"
                    Style="{StaticResource AloneElevatedCardBorderStyle}">
                    <Grid Padding="{StaticResource AloneListCardPadding}" ColumnSpacing="{StaticResource AloneSpace16}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.Column="0"
                            Width="52"
                            Height="52"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="{ThemeResource AloneSurfaceContainerHighBrush}"
                            CornerRadius="{StaticResource CornerRadiusSmall}">
                            <Viewbox
                                Width="26"
                                Height="26"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <SymbolIcon Foreground="{ThemeResource AlonePrimaryBrush}" Symbol="Library" />
                            </Viewbox>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="{StaticResource AloneSpace8}">
                            <Grid ColumnSpacing="{StaticResource AloneSpace12}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:ConnectionId='7'
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource AloneListCardTitleStyle}"
                                                                      />
                                <Border x:ConnectionId='8'
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                                                                                                                         
                                    Style="{StaticResource AloneStatusChipBorderStyle}">
                                    <TextBlock x:ConnectionId='9'
                                        MaxWidth="120"
                                        Foreground="{ThemeResource AloneOnSurfaceVariantBrush}"
                                        Style="{StaticResource AloneStatusChipTextStyle}"
                                                                           
                                        TextTrimming="CharacterEllipsis" />
                                </Border>
                            </Grid>
                            <TextBlock x:ConnectionId='5'
                                Style="{StaticResource AloneListCardMetaStyle}"
                                                                         />
                            <ProgressBar x:ConnectionId='6'
                                Height="4"
                                Maximum="1"
                                                                           
                                Foreground="{ThemeResource AloneSecondaryContainerBrush}"
                                Background="{ThemeResource AloneSurfaceContainerHighBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>
    </Page.Resources>
    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar x:ConnectionId='10'
            Grid.Row="0"
            Margin="{StaticResource AloneMarginBottom12}"
            IsClosable="True"
                                                                                                                          
                                                                 
            Severity="Error"
                                           />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <controls:ListEmptyState x:ConnectionId='21'
                    Margin="{StaticResource AloneMarginTop24}"
                    Title="准备好开启你的下一个伟大的 Side Project 了吗？"
                    Description="代码还没写，Bug 还没来，真香。先建个项目，把想法落进 SQLite。"
                    Glyph="&#xE8F1;"
                                                                                               
                    PrimaryLabel="新建项目"
                                                                                      />

                <StackPanel x:ConnectionId='22'
                    Margin="{StaticResource AloneMarginTop24}"
                    HorizontalAlignment="Center"
                    Spacing="{StaticResource AloneSpace8}"
                                                                                  >
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource AloneListCardMetaStyle}"
                        Text="无匹配项目，请调整筛选或搜索关键词。" />
                </StackPanel>

                <ScrollViewer x:ConnectionId='23'
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                                                                               >
                    <StackPanel Spacing="{StaticResource AloneListCardSpacing}">
                        <ItemsControl x:ConnectionId='24'
                            ItemTemplate="{StaticResource ProjectRowCardTemplate}"
                                                                                   />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Border x:ConnectionId='11'
                x:Name="DetailPanel"
                Grid.Column="1"
                Margin="{StaticResource AloneDetailPanelMargin}"
                Width="{StaticResource DetailPanelWidth}"
                HorizontalAlignment="Stretch"
                Style="{StaticResource AloneDetailPanelBorderStyle}"
                                                                                  >
                <StackPanel Spacing="{StaticResource AloneSpace12}">
                    <TextBlock x:ConnectionId='12' Style="{StaticResource AloneTitleLgTextBlockStyle}"                                                    />
                    <TextBlock x:ConnectionId='13' Style="{StaticResource AloneLabelMdTextBlockStyle}"                                                     />
                    <TextBlock x:ConnectionId='14'
                        TextWrapping="WrapWholeWords"
                        Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                                          />
                    <TextBlock x:ConnectionId='15' Style="{StaticResource AloneBodyMdTextBlockStyle}"                                                    />
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace8}">
                        <Button x:ConnectionId='17'
                                                                                                 
                            Content="编辑"
                                                                                     
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                        <Button x:ConnectionId='18'
                                                                                            
                            Content="归档"
                            Style="{StaticResource AloneSecondaryButtonStyle}"
                                                                                                 />
                        <Button x:ConnectionId='19'
                                                                                            
                            Content="恢复"
                            Style="{StaticResource AloneSecondaryButtonStyle}"
                                                                                                 />
                        <Button x:ConnectionId='20'
                                                       
                            Content="删除"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                    <Button x:ConnectionId='16'
                        HorizontalAlignment="Stretch"
                                                                                       
                        Content="关闭详情"
                        Style="{StaticResource AloneSecondaryButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

