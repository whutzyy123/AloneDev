<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:ConnectionId='1'
    x:Class="PMTool.App.Controls.GlobalSearchPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:Name="SearchPanelRoot"
                                        
    Padding="0"
    mc:Ignorable="d">
    <Border x:ConnectionId='2'
        x:Name="FlyoutRootBorder"
        MaxHeight="520"
        Padding="8"
        HorizontalAlignment="Stretch"
        Background="Transparent"
        CornerRadius="{StaticResource DefaultCornerRadius}">
        <Grid RowSpacing="{StaticResource AloneSpace8}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Spacing="{StaticResource AloneSpace8}">
                <Border x:ConnectionId='16'
                    Padding="10,6,10,6"
                    Background="{ThemeResource AloneSurfaceContainerHighBrush}"
                    CornerRadius="{StaticResource DefaultCornerRadius}"
                                                                                                                                  >
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace8}">
                        <TextBlock x:ConnectionId='22'
                            VerticalAlignment="Center"
                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                                                />
                        <Button x:ConnectionId='23'
                            Padding="6,2,6,2"
                                                                                          
                            Content="全库"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                </Border>
                <TextBlock Style="{StaticResource AloneCaptionTextBlockStyle}" Text="搜索范围（默认当前模块，可切换）" />
                <StackPanel Spacing="4">
                    <CheckBox x:ConnectionId='17' Content="项目"                                                           />
                    <CheckBox x:ConnectionId='18' Content="模块"                                                           />
                    <CheckBox x:ConnectionId='19' Content="任务"                                                        />
                    <CheckBox x:ConnectionId='20' Content="文档"                                                            />
                    <CheckBox x:ConnectionId='21' Content="灵感"                                                        />
                </StackPanel>
            </StackPanel>
            <TextBlock x:ConnectionId='3'
                Grid.Row="1"
                Foreground="{ThemeResource AloneWarningBrush}"
                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                                 
                TextWrapping="WrapWholeWords"
                                                                                                                                        />
            <ScrollViewer
                Grid.Row="2"
                MaxHeight="280"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled">
                <ItemsControl x:ConnectionId='6'                                                     >
                    <ItemsControl.ItemTemplate>
                        <DataTemplate                                           >
                            <StackPanel x:ConnectionId='8' Margin="0,0,0,8" Spacing="4">
                                <TextBlock x:ConnectionId='9' Style="{StaticResource AloneLabelMdTextBlockStyle}"                                    />
                                <Button x:ConnectionId='10'
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Background="Transparent"
                                    BorderThickness="0"
                                                                                       
                                                                                    
                                    CornerRadius="{StaticResource DefaultCornerRadius}"
                                                                                                                                             />
                                <ItemsControl x:ConnectionId='11'                                                  >
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate                                            >
                                            <Button x:ConnectionId='13'
                                                Margin="0,0,0,4"
                                                Padding="8,6"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                                                                                                                                 
                                                                       
                                                                          
                                                Style="{StaticResource AloneGlobalSearchHitButtonStyle}">
                                                <StackPanel Spacing="2">
                                                    <TextBlock x:ConnectionId='14'
                                                        MaxLines="1"
                                                        Style="{StaticResource AloneTitleSmTextBlockStyle}"
                                                                                          
                                                        TextTrimming="CharacterEllipsis" />
                                                    <local:HighlightedSnippetBlock x:ConnectionId='15'
                                                                                                         
                                                                                             />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <StackPanel
                Grid.Row="3"
                Orientation="Horizontal"
                Spacing="{StaticResource AloneSpace8}"
                VerticalAlignment="Center">
                <ProgressRing x:ConnectionId='4'
                    Width="22"
                    Height="22"
                    VerticalAlignment="Center"
                                                                          
                                                                                                                                   />
                <TextBlock x:ConnectionId='5'
                    VerticalAlignment="Center"
                    Style="{StaticResource AloneBodySecondaryTextBlockStyle}"
                                                                        
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

