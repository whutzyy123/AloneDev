<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:ConnectionId='1'
    x:Class="PMTool.App.Controls.OperationBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Controls"
    xmlns:models="using:PMTool.App.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
                                   
    mc:Ignorable="d">
    <Border
        Background="{ThemeResource AloneChromeElevatedBrush}"
        Shadow="{StaticResource AloneFloatThemeShadow}">
        <Grid
            Height="{StaticResource OperationBarHeight}"
            Padding="{StaticResource AloneOperationBarPadding}"
            Background="Transparent"
            ColumnSpacing="{StaticResource AloneSpace16}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock x:ConnectionId='2'
            Grid.Column="0"
            VerticalAlignment="Center"
            Style="{StaticResource AlonePageTitleTextBlockStyle}"
                                               />
        <StackPanel
            Grid.Column="2"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="{StaticResource AloneSpace8}">
            <Button
                Style="{StaticResource AloneChromeButtonStyle}"
                IsEnabled="{Binding IsOperationBarInteractive, Mode=OneWay}">
                <Button.Flyout>
                    <Flyout
                        FlyoutPresenterStyle="{StaticResource AloneFlyoutPresenterStyle}"
                        Placement="BottomEdgeAlignedLeft">
                        <ScrollViewer MaxHeight="320">
                            <ItemsControl IsTabStop="False" ItemsSource="{Binding FilterMenuItems, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate                                         >
                                        <HyperlinkButton x:ConnectionId='6'
                                            Margin="{StaticResource AloneHyperlinkFlyoutItemMargin}"
                                                                      
                                                                    />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Flyout>
                </Button.Flyout>
                <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace8}">
                    <FontIcon
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="{StaticResource BodyMdFontSize}"
                        Glyph="&#xE71C;" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding FilterButtonText, Mode=OneWay}" />
                </StackPanel>
            </Button>
            <Button
                Style="{StaticResource AloneChromeButtonStyle}"
                IsEnabled="{Binding IsOperationBarInteractive, Mode=OneWay}">
                <Button.Flyout>
                    <Flyout
                        FlyoutPresenterStyle="{StaticResource AloneFlyoutPresenterStyle}"
                        Placement="BottomEdgeAlignedLeft">
                        <ScrollViewer MaxHeight="320">
                            <ItemsControl IsTabStop="False" ItemsSource="{Binding SortMenuItems, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate                                         >
                                        <HyperlinkButton x:ConnectionId='4'
                                            Margin="{StaticResource AloneHyperlinkFlyoutItemMargin}"
                                                                      
                                                                    />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Flyout>
                </Button.Flyout>
                <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace8}">
                    <FontIcon
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="{StaticResource BodyMdFontSize}"
                        Glyph="&#xE8CB;" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding SortButtonText, Mode=OneWay}" />
                </StackPanel>
            </Button>
            <Button
                Command="{Binding PrimaryActionCommand}"
                Content="{Binding PrimaryActionLabel, Mode=OneWay}"
                IsEnabled="{Binding IsOperationBarInteractive, Mode=OneWay}"
                Style="{StaticResource AlonePrimaryButtonStyle}"
                Visibility="{Binding PrimaryActionLabel, Mode=OneWay, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" />
        </StackPanel>
        </Grid>
    </Border>
</UserControl>

