<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Thickness x:Key="AloneDialogContentPadding">24,20,24,16</Thickness>

    <Style x:Key="AloneContentDialogStyle" TargetType="ContentDialog">
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
    </Style>

    <Style
        x:Key="AloneDialogPrimaryButtonStyle"
        BasedOn="{StaticResource AlonePrimaryButtonStyle}"
        TargetType="Button" />

    <Style
        x:Key="AloneDialogCloseButtonStyle"
        BasedOn="{StaticResource AloneSecondaryButtonStyle}"
        TargetType="Button" />

    <Style
        x:Key="AloneDialogSecondaryButtonStyle"
        BasedOn="{StaticResource AloneSecondaryButtonStyle}"
        TargetType="Button" />

    <Style
        x:Key="AloneDialogDestructivePrimaryButtonStyle"
        BasedOn="{StaticResource AloneSecondaryButtonStyle}"
        TargetType="Button">
        <Setter Property="Foreground" Value="{ThemeResource AloneErrorBrush}" />
    </Style>

    <Style x:Key="AloneFlyoutPresenterStyle" TargetType="FlyoutPresenter">
        <Setter Property="Padding" Value="{StaticResource AloneFlyoutPanelPadding}" />
        <Setter Property="Background" Value="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
    </Style>

    <!-- 全局搜索：与顶栏搜索锚点等宽，不在外层再加 Padding -->
    <Style
        x:Key="AloneGlobalSearchFlyoutPresenterStyle"
        BasedOn="{StaticResource AloneFlyoutPresenterStyle}"
        TargetType="FlyoutPresenter">
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style
        x:Key="AloneFormTextBoxStyle"
        BasedOn="{StaticResource DefaultTextBoxStyle}"
        TargetType="TextBox">
        <Setter Property="PlaceholderForeground" Value="{ThemeResource AloneOnSurfaceVariantBrush}" />
    </Style>

    <Style
        x:Key="AloneFormNumberBoxStyle"
        BasedOn="{StaticResource DefaultNumberBoxStyle}"
        TargetType="NumberBox" />

    <Style
        x:Key="AloneFormToggleSwitchStyle"
        BasedOn="{StaticResource DefaultToggleSwitchStyle}"
        TargetType="ToggleSwitch">
        <Setter Property="MinWidth" Value="0" />
    </Style>
</ResourceDictionary>
