<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Flat-by-default: do not apply float shadow to list cards or shell panels.
        DESIGN target (~32 blur, 8 Y, 6% on-surface): WinUI ThemeShadow is system-styled; these keys document intent / future template use.
    -->
    <x:Double x:Key="AloneShadowBlurFloat">32</x:Double>
    <x:Double x:Key="AloneShadowOffsetYFloat">8</x:Double>
    <x:Double x:Key="AloneShadowOpacityFloat">0.06</x:Double>

    <ThemeShadow x:Key="AloneFloatThemeShadow" />

    <!-- Root for flyouts, global search chrome, menus only -->
    <Style x:Key="AloneFloatChromeBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AloneSurfaceContainerLowestBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Shadow" Value="{StaticResource AloneFloatThemeShadow}" />
    </Style>

    <!-- 列表卡片：无 ThemeShadow（避免虚拟化列表每层一遍阴影）；层次靠画布/卡片色阶与顶栏浮层 -->
    <Style x:Key="AloneElevatedCardBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusLarge}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="AloneDetailPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AloneSurfaceContainerLowestBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusLarge}" />
        <Setter Property="Shadow" Value="{StaticResource AloneFloatThemeShadow}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource AlonePadding16}" />
    </Style>
</ResourceDictionary>
