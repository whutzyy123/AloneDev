<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ThemeShadow：顶栏/操作栏、侧栏壳、主 Frame 壳、Flyout 根等；列表虚拟化内卡片仍不加 Shadow（性能）；看板卡片见 AloneKanbanCardBorderStyle。
        DESIGN float (~32 blur, 8 Y, 6% on-surface)：WinUI ThemeShadow 由系统绘制；下列 double 作文档意向。
        shadow-md（CSS 意向 0 4px 20px rgba(0,0,0,0.08)）：无 WinRT box-shadow，下列为设计标注；卡片微阴影仍用 ThemeShadow 近似。
    -->
    <x:Double x:Key="AloneShadowBlurFloat">32</x:Double>
    <x:Double x:Key="AloneShadowOffsetYFloat">8</x:Double>
    <x:Double x:Key="AloneShadowOpacityFloat">0.06</x:Double>
    <x:Double x:Key="AloneShadowMdOffsetYFloat">4</x:Double>
    <x:Double x:Key="AloneShadowMdBlurFloat">20</x:Double>
    <x:Double x:Key="AloneShadowMdOpacityFloat">0.08</x:Double>

    <ThemeShadow x:Key="AloneFloatThemeShadow" />

    <!-- Root for flyouts, global search chrome, menus only -->
    <Style x:Key="AloneFloatChromeBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AloneSurfaceContainerLowestBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Shadow" Value="{StaticResource AloneFloatThemeShadow}" />
    </Style>

    <!-- 列表卡片：1px 极浅描边；不加 ThemeShadow（虚拟化列表性能） -->
    <Style x:Key="AloneElevatedCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AloneSurfaceContainerLowestBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AloneCardOutlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- 看板拖拽卡片：量少于长列表，允许 ThemeShadow 抬升层级 -->
    <Style
        x:Key="AloneKanbanCardBorderStyle"
        BasedOn="{StaticResource AloneElevatedCardBorderStyle}"
        TargetType="Border">
        <Setter Property="Shadow" Value="{StaticResource AloneFloatThemeShadow}" />
    </Style>

    <Style x:Key="AloneDetailPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AloneSurfaceContainerLowestBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusLarge}" />
        <Setter Property="Shadow" Value="{StaticResource AloneFloatThemeShadow}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource AlonePadding16}" />
    </Style>
</ResourceDictionary>
