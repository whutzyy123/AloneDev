<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style
        x:Key="AlonePrimaryButtonStyle"
        BasedOn="{StaticResource AccentButtonStyle}"
        TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource AlonePrimaryGradientBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Padding" Value="18,11" />
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource BodyMdFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="AloneSecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource AloneSurfaceContainerHighBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource BodyMdFontSize}" />
    </Style>

    <!-- 对话框取消 / 次要操作：透明底，悬停轻垫 -->
    <Style
        x:Key="AloneGhostButtonStyle"
        BasedOn="{StaticResource DefaultButtonStyle}"
        TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource BodyMdFontSize}" />
    </Style>

    <Style x:Key="AloneSecondaryToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="{ThemeResource AloneSurfaceContainerHighBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource BodyMdFontSize}" />
    </Style>

    <Style x:Key="AloneNavItemButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceVariantBrush}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Toolbar: filter/sort — flat, small radius, no border -->
    <Style
        x:Key="AloneChromeButtonStyle"
        BasedOn="{StaticResource DefaultButtonStyle}"
        TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource AloneSurfaceBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource AloneOnSurfaceBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource AloneChromeButtonPadding}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="{StaticResource BodyMdFontSize}" />
    </Style>

    <!-- 全局下拉：更宽内边距；下拉项 Padding 与选中底受 Colors 中 SystemControlHighlightList* 覆盖。应用级隐式 Style 见 App.xaml（需在 MergedDictionaries 之后）。 -->
    <Style
        x:Key="AloneComboBoxStyle"
        BasedOn="{StaticResource DefaultComboBoxStyle}"
        TargetType="ComboBox">
        <Setter Property="Padding" Value="12,8,12,8" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource AloneComboBoxItemStyle}" />
    </Style>

    <Style
        x:Key="AloneComboBoxItemStyle"
        BasedOn="{StaticResource DefaultComboBoxItemStyle}"
        TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="14,10,14,10" />
    </Style>
</ResourceDictionary>
