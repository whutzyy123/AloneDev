<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 与列表卡片舒适档一致，长表单节内边距 -->
    <Thickness x:Key="AloneFormSectionCardPadding">16,14,16,14</Thickness>
    <x:Double x:Key="AloneFormSectionSpacing">20</x:Double>
    <Thickness x:Key="AloneFormPageScrollBottomPadding">0,0,0,24</Thickness>
    <Thickness x:Key="AloneFormPageStickyFooterPadding">16,12,16,12</Thickness>

    <Style x:Key="AloneFormSectionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AloneSurfaceContainerLowBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource AloneFormSectionCardPadding}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style
        x:Key="AloneFormSectionTitleStyle"
        BasedOn="{StaticResource AloneTitleSmTextBlockStyle}"
        TargetType="TextBlock" />

    <Style
        x:Key="AloneFormSectionDescriptionStyle"
        BasedOn="{StaticResource AloneBodySecondaryTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <!-- 长页底部固定操作条（与内容区分层，无描边） -->
    <Style x:Key="AloneFormPageStickyFooterStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AloneSurfaceContainerLowBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource AloneFormPageStickyFooterPadding}" />
    </Style>
</ResourceDictionary>
