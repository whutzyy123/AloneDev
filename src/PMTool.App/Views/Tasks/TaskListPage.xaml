<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PMTool.App.Views.Tasks.TaskListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PMTool.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Views.Tasks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:Name="TaskPageRoot"
    x:DataType="local:TaskListPage"
    Background="{ThemeResource AloneSurfaceBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="TaskKanbanCardTemplate" x:DataType="vm:TaskRowViewModel">
            <Border
                Margin="{StaticResource AloneMarginBottomListCard}"
                Padding="{StaticResource AloneListCardPadding}"
                HorizontalAlignment="Stretch"
                Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                CanDrag="True"
                DragStarting="TaskKanbanCard_DragStarting"
                Style="{StaticResource AloneElevatedCardBorderStyle}">
                <Grid ColumnSpacing="{StaticResource AloneSpace12}" Tapped="TaskKanbanCard_Tapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Rectangle
                        Grid.Column="0"
                        Width="4"
                        VerticalAlignment="Stretch"
                        Fill="{x:Bind TaskType, Converter={StaticResource TaskTypeAccentBrushConverter}, Mode=OneWay}"
                        RadiusX="2"
                        RadiusY="2" />
                    <StackPanel Grid.Column="1" Spacing="{StaticResource AloneSpace8}">
                    <Grid ColumnSpacing="{StaticResource AloneSpace12}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Style="{StaticResource AloneListCardTitleStyle}"
                            Text="{x:Bind Name, Mode=OneWay}" />
                        <Border
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Style="{StaticResource AloneStatusChipBorderStyle}">
                            <TextBlock
                                MaxWidth="120"
                                Style="{StaticResource AloneStatusChipTextStyle}"
                                Text="{x:Bind Status, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                        </Border>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace8}">
                        <TextBlock Style="{StaticResource AloneListCardMetaStyle}" Text="{x:Bind TaskType, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.5"
                            Style="{StaticResource AloneListCardMetaStyle}"
                            Text="·" />
                        <TextBlock Style="{StaticResource AloneListCardMetaStyle}" Text="{x:Bind SeverityDisplay, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.5"
                            Style="{StaticResource AloneListCardMetaStyle}"
                            Text="·" />
                        <TextBlock Style="{StaticResource AloneListCardMetaStyle}" Text="{x:Bind UpdatedAt, Mode=OneWay}" />
                    </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>
    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="{StaticResource AloneMarginBottom16}" Spacing="{StaticResource AloneSpace12}">
            <StackPanel Spacing="{StaticResource AloneSpace8}">
                <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="所属项目" />
                <ComboBox
                    MinWidth="280"
                    HorizontalAlignment="Left"
                    DisplayMemberPath="Name"
                    ItemsSource="{x:Bind ViewModel.ProjectOptions, Mode=OneWay}"
                    SelectedValue="{x:Bind ViewModel.SelectedProjectId, Mode=TwoWay}"
                    SelectedValuePath="Id" />
            </StackPanel>
            <StackPanel Spacing="{StaticResource AloneSpace8}">
                <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="所属特性" />
                <ComboBox
                    MinWidth="280"
                    HorizontalAlignment="Left"
                    DisplayMemberPath="Name"
                    ItemsSource="{x:Bind ViewModel.FeatureOptions, Mode=OneWay}"
                    SelectedValue="{x:Bind ViewModel.SelectedFeatureId, Mode=TwoWay}"
                    SelectedValuePath="Id" />
            </StackPanel>
        </StackPanel>

        <InfoBar
            Grid.Row="1"
            Margin="{StaticResource AloneMarginBottom12}"
            IsClosable="True"
            IsOpen="{x:Bind ViewModel.ErrorBanner, Mode=OneWay, Converter={StaticResource StringNotEmptyToBoolConverter}}"
            Message="{x:Bind ViewModel.ErrorBanner, Mode=OneWay}"
            Severity="Error"
            Closing="ErrorInfoBar_Closing" />

        <Grid Grid.Row="2" Margin="{StaticResource AloneMarginBottom8}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel
                Grid.Row="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="{StaticResource AloneSpace12}">
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource AloneLabelMdTextBlockStyle}"
                    Text="视图" />
                <ToggleButton
                    VerticalAlignment="Center"
                    Content="看板视图"
                    IsChecked="{x:Bind ViewModel.IsKanbanView, Mode=TwoWay}"
                    Style="{StaticResource AloneSecondaryToggleButtonStyle}" />
            </StackPanel>
                <Grid
                Grid.Row="1"
                Margin="{StaticResource AloneMarginTop8}"
                Visibility="{x:Bind ViewModel.TableHeaderVisibility, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Width="4"
                    Background="Transparent"
                    CornerRadius="0" />
                <TextBlock
                    Grid.Column="1"
                    Padding="{StaticResource AloneNavItemPadding}"
                    Style="{StaticResource AloneLabelMdTextBlockStyle}"
                    Text="名称" />
                <TextBlock
                    Grid.Column="2"
                    Width="88"
                    Padding="{StaticResource AloneNavItemPadding}"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AloneLabelMdTextBlockStyle}"
                    Text="类型" />
                <TextBlock
                    Grid.Column="3"
                    Width="80"
                    Padding="{StaticResource AloneNavItemPadding}"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AloneLabelMdTextBlockStyle}"
                    Text="状态" />
                <TextBlock
                    Grid.Column="4"
                    Width="72"
                    Padding="{StaticResource AloneNavItemPadding}"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AloneLabelMdTextBlockStyle}"
                    Text="严重" />
                <TextBlock
                    Grid.Column="5"
                    Width="140"
                    Padding="{StaticResource AloneNavItemPadding}"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AloneLabelMdTextBlockStyle}"
                    Text="更新时间" />
            </Grid>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <StackPanel
                    Margin="{StaticResource AloneMarginTop24}"
                    HorizontalAlignment="Center"
                    Spacing="{StaticResource AloneSpace8}"
                    Visibility="{x:Bind ViewModel.EmptyProjectsVisibility, Mode=OneWay}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource AloneListCardMetaStyle}"
                        Text="暂无项目，请先在「项目」模块创建项目" />
                </StackPanel>

                <StackPanel
                    Margin="{StaticResource AloneMarginTop24}"
                    HorizontalAlignment="Center"
                    Spacing="{StaticResource AloneSpace8}"
                    Visibility="{x:Bind ViewModel.SelectProjectVisibility, Mode=OneWay}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource AloneListCardMetaStyle}"
                        Text="请选择项目" />
                </StackPanel>

                <StackPanel
                    Margin="{StaticResource AloneMarginTop24}"
                    HorizontalAlignment="Center"
                    Spacing="{StaticResource AloneSpace8}"
                    Visibility="{x:Bind ViewModel.SelectFeatureVisibility, Mode=OneWay}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource AloneListCardMetaStyle}"
                        Text="该项目下暂无特性或请选择特性" />
                </StackPanel>

                <controls:ListEmptyState
                    Margin="{StaticResource AloneMarginTop24}"
                    Title="当前特性暂无任务"
                    Description="创建任务以跟踪实现、缺陷与研究项。"
                    Glyph="&#xE90F;"
                    PrimaryCommand="{x:Bind ViewModel.RequestNewTaskUiCommand, Mode=OneWay}"
                    PrimaryLabel="新建任务"
                    Visibility="{x:Bind ViewModel.GlobalEmptyVisibility, Mode=OneWay}" />

                <StackPanel
                    Margin="{StaticResource AloneMarginTop24}"
                    HorizontalAlignment="Center"
                    Spacing="{StaticResource AloneSpace8}"
                    Visibility="{x:Bind ViewModel.NoMatchVisibility, Mode=OneWay}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource AloneListCardMetaStyle}"
                        Text="无匹配任务，请调整筛选或搜索关键词。" />
                </StackPanel>

                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{x:Bind ViewModel.TableMainVisibility, Mode=OneWay}">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Tasks, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TaskRowViewModel">
                                <Button
                                    Margin="{StaticResource AloneMarginBottomListCard}"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding ElementName=TaskPageRoot, Path=ViewModel.SelectTaskRowCommand}"
                                    CommandParameter="{x:Bind}"
                                    CornerRadius="{StaticResource CornerRadiusLarge}">
                                    <Border
                                        Padding="{StaticResource AloneListCardPadding}"
                                        HorizontalAlignment="Stretch"
                                        Background="{x:Bind IsSearchHighlight, Converter={StaticResource SearchRowBackgroundConverter}, Mode=OneWay}"
                                        CornerRadius="{StaticResource CornerRadiusLarge}"
                                        Style="{StaticResource AloneElevatedCardBorderStyle}">
                                        <Grid ColumnSpacing="{StaticResource AloneSpace12}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="140" />
                                            </Grid.ColumnDefinitions>
                                            <Rectangle
                                                Grid.Column="0"
                                                Width="4"
                                                VerticalAlignment="Stretch"
                                                Fill="{x:Bind TaskType, Converter={StaticResource TaskTypeAccentBrushConverter}, Mode=OneWay}"
                                                RadiusX="2"
                                                RadiusY="2" />
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneListCardTitleStyle}"
                                                Text="{x:Bind Name, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneListCardMetaStyle}"
                                                Text="{x:Bind TaskType, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="3"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneListCardMetaStyle}"
                                                Text="{x:Bind Status, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="4"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneListCardMetaStyle}"
                                                Text="{x:Bind SeverityDisplay, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="5"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Opacity="0.88"
                                                Style="{StaticResource AloneListCardMetaStyle}"
                                                Text="{x:Bind UpdatedAt, Mode=OneWay}" />
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Visibility="{x:Bind ViewModel.KanbanMainVisibility, Mode=OneWay}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="KanbanTaskCol0"
                        Grid.Column="0"
                        Margin="0,0,6,0"
                        Padding="{StaticResource AlonePadding8}"
                        VerticalAlignment="Stretch"
                        AllowDrop="True"
                        Background="{ThemeResource AloneKanbanColumnBrush0}"
                        CornerRadius="{StaticResource CornerRadiusLarge}"
                        DragOver="TaskKanbanColumn_DragOver"
                        Drop="TaskKanbanColumn_Drop"
                        Tag="未开始">
                        <Grid RowSpacing="{StaticResource AloneSpace8}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="未开始" />
                            <ScrollViewer
                                Grid.Row="1"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                                <ItemsControl
                                    ItemTemplate="{StaticResource TaskKanbanCardTemplate}"
                                    ItemsSource="{x:Bind ViewModel.KanbanTasksNotStarted, Mode=OneWay}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border
                        x:Name="KanbanTaskCol1"
                        Grid.Column="1"
                        Margin="6,0,6,0"
                        Padding="{StaticResource AlonePadding8}"
                        VerticalAlignment="Stretch"
                        AllowDrop="True"
                        Background="{ThemeResource AloneKanbanColumnBrush1}"
                        CornerRadius="{StaticResource CornerRadiusLarge}"
                        DragOver="TaskKanbanColumn_DragOver"
                        Drop="TaskKanbanColumn_Drop"
                        Tag="进行中">
                        <Grid RowSpacing="{StaticResource AloneSpace8}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="进行中" />
                            <ScrollViewer
                                Grid.Row="1"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                                <ItemsControl
                                    ItemTemplate="{StaticResource TaskKanbanCardTemplate}"
                                    ItemsSource="{x:Bind ViewModel.KanbanTasksInProgress, Mode=OneWay}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border
                        x:Name="KanbanTaskCol2"
                        Grid.Column="2"
                        Margin="6,0,6,0"
                        Padding="{StaticResource AlonePadding8}"
                        VerticalAlignment="Stretch"
                        AllowDrop="True"
                        Background="{ThemeResource AloneKanbanColumnBrush2}"
                        CornerRadius="{StaticResource CornerRadiusLarge}"
                        DragOver="TaskKanbanColumn_DragOver"
                        Drop="TaskKanbanColumn_Drop"
                        Tag="已完成">
                        <Grid RowSpacing="{StaticResource AloneSpace8}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="已完成" />
                            <ScrollViewer
                                Grid.Row="1"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                                <ItemsControl
                                    ItemTemplate="{StaticResource TaskKanbanCardTemplate}"
                                    ItemsSource="{x:Bind ViewModel.KanbanTasksDone, Mode=OneWay}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border
                        x:Name="KanbanTaskCol3"
                        Grid.Column="3"
                        Margin="6,0,0,0"
                        Padding="{StaticResource AlonePadding8}"
                        VerticalAlignment="Stretch"
                        AllowDrop="True"
                        Background="{ThemeResource AloneKanbanColumnBrush3}"
                        CornerRadius="{StaticResource CornerRadiusLarge}"
                        DragOver="TaskKanbanColumn_DragOver"
                        Drop="TaskKanbanColumn_Drop"
                        Tag="已取消">
                        <Grid RowSpacing="{StaticResource AloneSpace8}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="已取消" />
                            <ScrollViewer
                                Grid.Row="1"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                                <ItemsControl
                                    ItemTemplate="{StaticResource TaskKanbanCardTemplate}"
                                    ItemsSource="{x:Bind ViewModel.KanbanTasksCancelled, Mode=OneWay}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border
                Grid.Column="1"
                Margin="{StaticResource AloneDetailPanelMargin}"
                Padding="{StaticResource AlonePadding16}"
                Width="{StaticResource DetailPanelWidth}"
                HorizontalAlignment="Stretch"
                Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                CornerRadius="{StaticResource DefaultCornerRadius}"
                Visibility="{x:Bind ViewModel.DetailPanelVisibility, Mode=OneWay}">
                <StackPanel Spacing="{StaticResource AloneSpace12}">
                    <TextBlock Style="{StaticResource AloneTitleLgTextBlockStyle}" Text="{x:Bind ViewModel.DetailTitle, Mode=OneWay}" />
                    <TextBlock
                        TextWrapping="WrapWholeWords"
                        Style="{StaticResource AloneBodyMdTextBlockStyle}"
                        Text="{x:Bind ViewModel.DetailMeta, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="调整顺序（同特性）" />
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace8}">
                        <Button
                            Command="{x:Bind ViewModel.MoveUpCommand, Mode=OneWay}"
                            Content="上移"
                            IsEnabled="{x:Bind ViewModel.CanMoveUp, Mode=OneWay}"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                        <Button
                            Command="{x:Bind ViewModel.MoveDownCommand, Mode=OneWay}"
                            Content="下移"
                            IsEnabled="{x:Bind ViewModel.CanMoveDown, Mode=OneWay}"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="状态" />
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.DetailAllowedStatuses, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.DetailStatusDraft, Mode=TwoWay}" />
                    <Button
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.ApplyDetailStatusCommand, Mode=OneWay}"
                        Content="应用状态"
                        Style="{StaticResource AloneSecondaryButtonStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace8}">
                        <Button
                            Command="{x:Bind ViewModel.RequestEditTaskUiCommand, Mode=OneWay}"
                            Content="编辑"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                        <Button
                            Click="DeleteTask_Click"
                            Content="删除"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                    <Button
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.ClearTaskSelectionCommand, Mode=OneWay}"
                        Content="关闭详情"
                        Style="{StaticResource AloneSecondaryButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
