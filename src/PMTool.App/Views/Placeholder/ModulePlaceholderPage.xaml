<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PMTool.App.Views.Placeholder.ModulePlaceholderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PMTool.App.Views.Placeholder"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DataType="local:ModulePlaceholderPage"
    mc:Ignorable="d">
    <Grid Padding="32" Background="{StaticResource AloneSurfaceBrush}">
        <StackPanel HorizontalAlignment="Center" Spacing="24" VerticalAlignment="Center">
            <TextBlock
                HorizontalAlignment="Center"
                Style="{StaticResource AloneDisplayMdTextBlockStyle}"
                Text="AloneDev"
                TextAlignment="Center" />
            <TextBlock
                HorizontalAlignment="Center"
                Opacity="0.85"
                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                Text="{x:Bind ViewModel.ModuleTitle, Mode=OneWay}"
                TextAlignment="Center" />
            <TextBlock
                HorizontalAlignment="Center"
                Opacity="0.7"
                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                Text="模块建设中"
                TextAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
