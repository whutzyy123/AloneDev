<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PMTool.App.Views.Features.FeatureListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PMTool.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Views.Features"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:Name="FeaturePageRoot"
    x:DataType="local:FeatureListPage"
    Background="{ThemeResource AloneSurfaceBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="FeatureKanbanCardTemplate" x:DataType="vm:FeatureRowViewModel">
            <Border
                Margin="{StaticResource AloneMarginBottomListCard}"
                Padding="{StaticResource AloneListCardPadding}"
                HorizontalAlignment="Stretch"
                Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                CanDrag="True"
                DragStarting="FeatureKanbanCard_DragStarting"
                Style="{StaticResource AloneKanbanCardBorderStyle}">
                <StackPanel Spacing="{StaticResource AloneSpace8}" Tapped="FeatureKanbanCard_Tapped">
                    <Grid ColumnSpacing="{StaticResource AloneSpace16}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Style="{StaticResource AloneListCardTitleStyle}"
                            Text="{x:Bind Name, Mode=OneWay}" />
                        <Border
                            Grid.Column="1"
                            Padding="6,2,6,2"
                            VerticalAlignment="Center"
                            Background="{ThemeResource AloneChipPriorityP0BackgroundBrush}"
                            CornerRadius="{StaticResource CornerRadiusSmall}"
                            Visibility="{x:Bind IsPriorityP0, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock
                                Foreground="{ThemeResource AloneChipPriorityP0ForegroundBrush}"
                                Style="{StaticResource AloneCaptionTextBlockStyle}"
                                FontWeight="SemiBold"
                                Text="P0" />
                        </Border>
                        <Border
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Style="{StaticResource AloneStatusChipBorderStyle}">
                            <TextBlock
                                MaxWidth="120"
                                Style="{StaticResource AloneStatusChipTextStyle}"
                                Text="{x:Bind Status, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                        </Border>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace8}">
                        <TextBlock Style="{StaticResource AloneListCardMetaStyle}" Text="{x:Bind PriorityLabel, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.5"
                            Style="{StaticResource AloneListCardMetaStyle}"
                            Text="·" />
                        <TextBlock Style="{StaticResource AloneListCardMetaStyle}" Text="{x:Bind UpdatedAt, Mode=OneWay}" />
                    </StackPanel>
                    <TextBlock
                        MaxLines="3"
                        Opacity="0.85"
                        Style="{StaticResource AloneListCardMetaStyle}"
                        Text="{x:Bind DescriptionPreview, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="WrapWholeWords"
                        Visibility="{x:Bind DescriptionPreview, Mode=OneWay, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>
    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Margin="{StaticResource AloneMarginBottom16}"
            Spacing="{StaticResource AloneSpace16}">
            <TextBlock
                MaxWidth="560"
                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                Text="模块用来按功能域拆分工作，适合个人项目里的「登录」「设置页」等粒度。碎片任务也可以不建模块，直接在「任务」里挂到项目下。"
                TextWrapping="WrapWholeWords" />
            <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="所属项目" />
            <ComboBox
                MinWidth="280"
                HorizontalAlignment="Left"
                Style="{StaticResource AloneComboBoxStyle}"
                DisplayMemberPath="Name"
                ItemsSource="{x:Bind ViewModel.ProjectOptions, Mode=OneWay}"
                SelectedValue="{x:Bind ViewModel.SelectedProjectId, Mode=TwoWay}"
                SelectedValuePath="Id" />
        </StackPanel>

        <InfoBar
            Grid.Row="1"
            Margin="{StaticResource AloneMarginBottom12}"
            IsClosable="True"
            IsOpen="{x:Bind ViewModel.ErrorBanner, Mode=OneWay, Converter={StaticResource StringNotEmptyToBoolConverter}}"
            Message="{x:Bind ViewModel.ErrorBanner, Mode=OneWay}"
            Severity="Error"
            Closing="ErrorInfoBar_Closing" />

        <Grid Grid.Row="2" Margin="{StaticResource AloneMarginBottom8}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel
                Grid.Row="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="{StaticResource AloneSpace16}">
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource AloneLabelMdTextBlockStyle}"
                    Text="视图" />
                <ToggleButton
                    VerticalAlignment="Center"
                    Content="看板"
                    IsChecked="{x:Bind ViewModel.IsKanbanView, Mode=TwoWay}"
                    Style="{StaticResource AloneSecondaryToggleButtonStyle}" />
            </StackPanel>
            <Grid
                Grid.Row="1"
                Margin="{StaticResource AloneMarginTop8}"
                Visibility="{x:Bind ViewModel.TableHeaderVisibility, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Padding="{StaticResource AloneNavItemPadding}"
                    Style="{StaticResource AloneLabelMdTextBlockStyle}"
                    Text="名称" />
                <TextBlock
                    Grid.Column="1"
                    Width="72"
                    Padding="{StaticResource AloneNavItemPadding}"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AloneLabelMdTextBlockStyle}"
                    Text="优先级" />
                <TextBlock
                    Grid.Column="2"
                    Width="88"
                    Padding="{StaticResource AloneNavItemPadding}"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AloneLabelMdTextBlockStyle}"
                    Text="状态" />
                <TextBlock
                    Grid.Column="3"
                    Width="140"
                    Padding="{StaticResource AloneNavItemPadding}"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AloneLabelMdTextBlockStyle}"
                    Text="更新时间" />
            </Grid>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <StackPanel
                    Margin="{StaticResource AloneMarginTop24}"
                    HorizontalAlignment="Center"
                    Spacing="{StaticResource AloneSpace8}"
                    Visibility="{x:Bind ViewModel.EmptyProjectsVisibility, Mode=OneWay}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource AloneListCardMetaStyle}"
                        Text="暂无项目，请先在「项目」模块创建项目" />
                </StackPanel>

                <StackPanel
                    Margin="{StaticResource AloneMarginTop24}"
                    HorizontalAlignment="Center"
                    Spacing="{StaticResource AloneSpace8}"
                    Visibility="{x:Bind ViewModel.SelectProjectVisibility, Mode=OneWay}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource AloneListCardMetaStyle}"
                        Text="请选择一个项目以查看模块" />
                </StackPanel>

                <controls:ListEmptyState
                    Margin="{StaticResource AloneMarginTop24}"
                    Title="当前项目暂无模块"
                    Description="新建模块以划分功能域；小任务也可只在「任务」页挂到项目上，不必先建模块。"
                    Glyph="&#xE8FD;"
                    PrimaryCommand="{x:Bind ViewModel.RequestNewFeatureUiCommand, Mode=OneWay}"
                    PrimaryLabel="新建模块"
                    Visibility="{x:Bind ViewModel.GlobalEmptyVisibility, Mode=OneWay}" />

                <StackPanel
                    Margin="{StaticResource AloneMarginTop24}"
                    HorizontalAlignment="Center"
                    Spacing="{StaticResource AloneSpace8}"
                    Visibility="{x:Bind ViewModel.NoMatchVisibility, Mode=OneWay}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource AloneListCardMetaStyle}"
                        Text="无匹配模块，请调整筛选或搜索关键词。" />
                </StackPanel>

                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{x:Bind ViewModel.TableMainVisibility, Mode=OneWay}">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Features, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:FeatureRowViewModel">
                                <Button
                                    Margin="{StaticResource AloneMarginBottomListCard}"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding ElementName=FeaturePageRoot, Path=ViewModel.SelectFeatureCommand}"
                                    CommandParameter="{x:Bind Mode=OneTime}"
                                    CornerRadius="{StaticResource CornerRadiusLarge}">
                                    <Border
                                        Padding="{StaticResource AloneListCardPadding}"
                                        HorizontalAlignment="Stretch"
                                        Background="{x:Bind IsSearchHighlight, Converter={StaticResource SearchRowBackgroundConverter}, Mode=OneWay}"
                                        CornerRadius="{StaticResource CornerRadiusLarge}"
                                        Style="{StaticResource AloneElevatedCardBorderStyle}">
                                        <Grid ColumnSpacing="{StaticResource AloneSpace16}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="140" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Spacing="{StaticResource AloneSpace4}">
                                                <TextBlock Style="{StaticResource AloneListCardTitleStyle}" Text="{x:Bind Name, Mode=OneWay}" />
                                                <TextBlock
                                                    MaxLines="2"
                                                    Opacity="0.82"
                                                    Style="{StaticResource AloneListCardMetaStyle}"
                                                    Text="{x:Bind DescriptionPreview, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="WrapWholeWords"
                                                    Visibility="{x:Bind DescriptionPreview, Mode=OneWay, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" />
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneListCardMetaStyle}"
                                                Text="{x:Bind PriorityLabel, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneListCardMetaStyle}"
                                                Text="{x:Bind Status, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="3"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Opacity="0.88"
                                                Style="{StaticResource AloneListCardMetaStyle}"
                                                Text="{x:Bind UpdatedAt, Mode=OneWay}" />
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid
                    ColumnSpacing="{StaticResource AloneKanbanColumnSpacing}"
                    Visibility="{x:Bind ViewModel.KanbanMainVisibility, Mode=OneWay}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="KanbanFeatureCol0"
                        Grid.Column="0"
                        Margin="0"
                        Padding="{StaticResource AlonePadding8}"
                        VerticalAlignment="Stretch"
                        AllowDrop="True"
                        Background="{ThemeResource AloneKanbanColumnBackgroundBrush}"
                        CornerRadius="{StaticResource CornerRadiusLarge}"
                        DragOver="FeatureKanbanColumn_DragOver"
                        Drop="FeatureKanbanColumn_Drop"
                        Tag="待规划">
                        <Grid RowSpacing="{StaticResource AloneSpace8}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Height="3"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource AloneKanbanColumnAccent0}"
                                CornerRadius="2,2,0,0" />
                            <TextBlock
                                Grid.Row="1"
                                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                                Text="待规划" />
                            <ScrollViewer
                                Grid.Row="2"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                                <ItemsControl
                                    ItemTemplate="{StaticResource FeatureKanbanCardTemplate}"
                                    ItemsSource="{x:Bind ViewModel.KanbanFeaturesToPlan, Mode=OneWay}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border
                        x:Name="KanbanFeatureCol1"
                        Grid.Column="1"
                        Margin="0"
                        Padding="{StaticResource AlonePadding8}"
                        VerticalAlignment="Stretch"
                        AllowDrop="True"
                        Background="{ThemeResource AloneKanbanColumnBackgroundBrush}"
                        CornerRadius="{StaticResource CornerRadiusLarge}"
                        DragOver="FeatureKanbanColumn_DragOver"
                        Drop="FeatureKanbanColumn_Drop"
                        Tag="进行中">
                        <Grid RowSpacing="{StaticResource AloneSpace8}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Height="3"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource AloneKanbanColumnAccent1}"
                                CornerRadius="2,2,0,0" />
                            <TextBlock
                                Grid.Row="1"
                                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                                Text="进行中" />
                            <ScrollViewer
                                Grid.Row="2"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                                <ItemsControl
                                    ItemTemplate="{StaticResource FeatureKanbanCardTemplate}"
                                    ItemsSource="{x:Bind ViewModel.KanbanFeaturesInProgress, Mode=OneWay}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border
                        x:Name="KanbanFeatureCol2"
                        Grid.Column="2"
                        Margin="0"
                        Padding="{StaticResource AlonePadding8}"
                        VerticalAlignment="Stretch"
                        AllowDrop="True"
                        Background="{ThemeResource AloneKanbanColumnBackgroundBrush}"
                        CornerRadius="{StaticResource CornerRadiusLarge}"
                        DragOver="FeatureKanbanColumn_DragOver"
                        Drop="FeatureKanbanColumn_Drop"
                        Tag="已完成">
                        <Grid RowSpacing="{StaticResource AloneSpace8}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Height="3"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource AloneKanbanColumnAccent2}"
                                CornerRadius="2,2,0,0" />
                            <TextBlock
                                Grid.Row="1"
                                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                                Text="已完成" />
                            <ScrollViewer
                                Grid.Row="2"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                                <ItemsControl
                                    ItemTemplate="{StaticResource FeatureKanbanCardTemplate}"
                                    ItemsSource="{x:Bind ViewModel.KanbanFeaturesDone, Mode=OneWay}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border
                        x:Name="KanbanFeatureCol3"
                        Grid.Column="3"
                        Margin="0"
                        Padding="{StaticResource AlonePadding8}"
                        VerticalAlignment="Stretch"
                        AllowDrop="True"
                        Background="{ThemeResource AloneKanbanColumnBackgroundBrush}"
                        CornerRadius="{StaticResource CornerRadiusLarge}"
                        DragOver="FeatureKanbanColumn_DragOver"
                        Drop="FeatureKanbanColumn_Drop"
                        Tag="已上线">
                        <Grid RowSpacing="{StaticResource AloneSpace8}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Height="3"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource AloneKanbanColumnAccent3}"
                                CornerRadius="2,2,0,0" />
                            <TextBlock
                                Grid.Row="1"
                                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                                Text="已上线" />
                            <ScrollViewer
                                Grid.Row="2"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                                <ItemsControl
                                    ItemTemplate="{StaticResource FeatureKanbanCardTemplate}"
                                    ItemsSource="{x:Bind ViewModel.KanbanFeaturesReleased, Mode=OneWay}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border
                Grid.Column="1"
                Margin="{StaticResource AloneDetailPanelMargin}"
                Padding="{StaticResource AlonePadding16}"
                Width="{StaticResource DetailPanelWidth}"
                HorizontalAlignment="Stretch"
                Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                CornerRadius="{StaticResource DefaultCornerRadius}"
                Visibility="{x:Bind ViewModel.DetailPanelVisibility, Mode=OneWay}">
                <StackPanel Spacing="{StaticResource AloneSpace16}">
                    <TextBlock Style="{StaticResource AloneTitleLgTextBlockStyle}" Text="{x:Bind ViewModel.DetailTitle, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource AloneBodyMdTextBlockStyle}" Text="{x:Bind ViewModel.DetailMeta, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="任务完成进度" />
                    <TextBlock
                        Opacity="0.9"
                        Style="{StaticResource AloneBodyMdTextBlockStyle}"
                        Text="{x:Bind ViewModel.DetailTaskProgressText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="可流转状态（禁止跨级前进）" />
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource AloneComboBoxStyle}"
                        ItemsSource="{x:Bind ViewModel.DetailAllowedStatuses, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.DetailStatusDraft, Mode=TwoWay}" />
                    <Button
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.ApplyDetailStatusCommand, Mode=OneWay}"
                        Content="应用状态"
                        Style="{StaticResource AloneSecondaryButtonStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace8}">
                        <Button
                            Command="{x:Bind ViewModel.RequestEditFeatureUiCommand, Mode=OneWay}"
                            Content="编辑"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                        <Button
                            Click="DeleteFeature_Click"
                            Content="删除"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                    <Button
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.ClearSelectionCommand, Mode=OneWay}"
                        Content="关闭详情"
                        Style="{StaticResource AloneSecondaryButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
