<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PMTool.App.Views.Ideas.IdeaListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:PMTool.App.Controls"
    xmlns:local="using:PMTool.App.Views.Ideas"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PMTool.App.Models"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:Name="IdeaPageRoot"
    x:DataType="local:IdeaListPage"
    Background="{ThemeResource AloneSurfaceBrush}"
    mc:Ignorable="d">
    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="{StaticResource AloneMarginTop24Bottom12}"
            Padding="12"
            Background="{ThemeResource AloneSurfaceContainerLowBrush}"
            CornerRadius="{StaticResource DefaultCornerRadius}"
            Visibility="{x:Bind ViewModel.ErrorBannerVisibility, Mode=OneWay}">
            <TextBlock
                Foreground="{ThemeResource AloneErrorBrush}"
                Text="{x:Bind ViewModel.ErrorBanner, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />
        </Border>

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,16"
            Orientation="Horizontal"
            Spacing="12">
            <Button Style="{StaticResource AloneChromeButtonStyle}">
                <Button.Flyout>
                    <Flyout
                        FlyoutPresenterStyle="{StaticResource AloneFlyoutPresenterStyle}"
                        Placement="BottomEdgeAlignedLeft">
                        <ScrollViewer MaxHeight="320">
                            <ItemsControl IsTabStop="False" ItemsSource="{x:Bind ViewModel.PriorityFilterMenuItems, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:OperationBarMenuItem">
                                        <HyperlinkButton
                                            Margin="0,4"
                                            Command="{x:Bind Command}"
                                            Content="{x:Bind Text}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Flyout>
                </Button.Flyout>
                <Button.Content>
                    <TextBlock Text="{x:Bind ViewModel.PriorityFilterButtonText, Mode=OneWay}" />
                </Button.Content>
            </Button>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="72" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Padding="8,4"
                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                Text="标题" />
            <TextBlock
                Grid.Column="1"
                Padding="8,4"
                HorizontalAlignment="Right"
                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                Text="优先级" />
            <TextBlock
                Grid.Column="2"
                MinWidth="120"
                Padding="8,4"
                HorizontalAlignment="Right"
                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                Text="状态" />
            <TextBlock
                Grid.Column="3"
                Padding="8,4"
                HorizontalAlignment="Right"
                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                Text="更新时间" />
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <controls:ListEmptyState
                    Margin="{StaticResource AloneMarginTop24}"
                    Title="还没有灵感"
                    Description="使用顶栏「新建灵感」开始记录，或点击下方按钮。"
                    Glyph="&#xE8F1;"
                    PrimaryCommand="{x:Bind ViewModel.RequestNewIdeaUiCommand, Mode=OneWay}"
                    PrimaryLabel="新建灵感"
                    Visibility="{x:Bind ViewModel.GlobalEmptyVisibility, Mode=OneWay}" />

                <controls:ListEmptyState
                    Margin="{StaticResource AloneMarginTop24}"
                    Title="无匹配灵感"
                    Description="请调整筛选或搜索关键词。"
                    IsPrimaryVisible="False"
                    Visibility="{x:Bind ViewModel.NoMatchVisibility, Mode=OneWay}" />

                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{x:Bind ViewModel.ListVisibility, Mode=OneWay}">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Ideas, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:IdeaRowViewModel">
                                <Button
                                    Margin="0,0,0,8"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding ElementName=IdeaPageRoot, Path=ViewModel.SelectIdeaRowCommand}"
                                    CommandParameter="{x:Bind}"
                                    CornerRadius="{StaticResource DefaultCornerRadius}">
                                    <Border
                                        Padding="8"
                                        HorizontalAlignment="Stretch"
                                        Background="{x:Bind IsSearchHighlight, Converter={StaticResource SearchRowBackgroundConverter}, Mode=OneWay}"
                                        CornerRadius="{StaticResource DefaultCornerRadius}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="140" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneTitleSmTextBlockStyle}"
                                                Text="{x:Bind Title, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                Text="{x:Bind PriorityLabel, Mode=OneWay}" />
                                            <StackPanel
                                                Grid.Column="2"
                                                MinWidth="120"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Spacing="8">
                                                <Border
                                                    Width="10"
                                                    Height="10"
                                                    VerticalAlignment="Center"
                                                    Background="{x:Bind StatusBrush, Mode=OneWay}"
                                                    CornerRadius="3" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                    Text="{x:Bind Status, Mode=OneWay}" />
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Column="3"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Opacity="0.85"
                                                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                Text="{x:Bind UpdatedAt, Mode=OneWay}" />
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border
                Grid.Column="1"
                Margin="{StaticResource AloneDetailPanelMargin}"
                Padding="16"
                Width="360"
                Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                CornerRadius="{StaticResource DefaultCornerRadius}"
                Visibility="{x:Bind ViewModel.DetailPanelVisibility, Mode=OneWay}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <TextBlock
                            Style="{StaticResource AloneTitleLgTextBlockStyle}"
                            Text="{x:Bind ViewModel.DetailIdea.Title, Mode=OneWay}" />
                        <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="描述" />
                        <TextBlock
                            Opacity="0.9"
                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                            Text="{x:Bind ViewModel.DetailIdea.Description, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="技术栈" />
                        <TextBlock
                            Opacity="0.9"
                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                            Text="{x:Bind ViewModel.DetailIdea.TechStack, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="状态（任意切换）" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            ItemsSource="{x:Bind ViewModel.IdeaStatusOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.DetailStatusSelection, Mode=TwoWay}" />
                        <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="优先级" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            ItemsSource="{x:Bind ViewModel.IdeaPriorityPickerValues, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.DetailPrioritySelection, Mode=TwoWay}" />
                        <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="关联项目（仅已立项）" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            DisplayMemberPath="Name"
                            IsEnabled="{x:Bind ViewModel.CanEditLinkedProject, Mode=OneWay}"
                            ItemsSource="{x:Bind ViewModel.ProjectOptions, Mode=OneWay}"
                            SelectedValue="{x:Bind ViewModel.DetailLinkedProjectId, Mode=TwoWay}"
                            SelectedValuePath="Id" />
                        <Button
                            HorizontalAlignment="Left"
                            Command="{x:Bind ViewModel.SaveLinkedProjectCommand, Mode=OneWay}"
                            Content="保存关联项目"
                            IsEnabled="{x:Bind ViewModel.CanEditLinkedProject, Mode=OneWay}"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                Command="{x:Bind ViewModel.RequestEditIdeaUiCommand, Mode=OneWay}"
                                Content="编辑全文"
                                Style="{StaticResource AloneSecondaryButtonStyle}" />
                            <Button
                                Click="DeleteIdea_Click"
                                Content="删除"
                                Style="{StaticResource AloneSecondaryButtonStyle}" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="关联文档" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                Command="{x:Bind ViewModel.RequestAddDocumentsUiCommand, Mode=OneWay}"
                                Content="添加关联"
                                Style="{StaticResource AloneSecondaryButtonStyle}" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.DetailDocLinks, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:IdeaDocLinkRowViewModel">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                            Text="{x:Bind DocumentName, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                        <Button
                                            Grid.Column="1"
                                            Command="{Binding ElementName=IdeaPageRoot, Path=ViewModel.RemoveDocLinkCommand}"
                                            CommandParameter="{x:Bind}"
                                            Content="移除"
                                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button
                            Command="{x:Bind ViewModel.ClearIdeaSelectionCommand, Mode=OneWay}"
                            Content="关闭详情"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
