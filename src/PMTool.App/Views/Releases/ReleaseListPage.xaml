<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PMTool.App.Views.Releases.ReleaseListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:PMTool.App.Controls"
    xmlns:local="using:PMTool.App.Views.Releases"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:Name="ReleasePageRoot"
    x:DataType="local:ReleaseListPage"
    Background="{ThemeResource AloneSurfaceBrush}"
    mc:Ignorable="d">
    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Margin="{StaticResource AloneMarginTop24}"
            Spacing="8">
            <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="所属项目" />
            <ComboBox
                MinWidth="280"
                HorizontalAlignment="Left"
                Style="{StaticResource AloneComboBoxStyle}"
                DisplayMemberPath="Name"
                ItemsSource="{x:Bind ViewModel.ProjectOptions, Mode=OneWay}"
                SelectedValue="{x:Bind ViewModel.SelectedProjectId, Mode=TwoWay}"
                SelectedValuePath="Id" />
            <InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="当前项目尚未关联本地 Git 仓库。可在「项目」中编辑项目并设置路径后，从提交记录生成变更说明。"
                Severity="Informational"
                Visibility="{x:Bind ViewModel.GitMissingHintVisibility, Mode=OneWay}" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Margin="0,12,0,12"
            Padding="{StaticResource AloneModuleChromePadding}"
            Background="{ThemeResource AloneSurfaceContainerLowBrush}"
            CornerRadius="{StaticResource DefaultCornerRadius}"
            Visibility="{x:Bind ViewModel.ErrorBannerVisibility, Mode=OneWay}">
            <TextBlock
                Foreground="{ThemeResource AloneErrorBrush}"
                Text="{x:Bind ViewModel.ErrorBanner, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="96" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Padding="8,4"
                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                Text="版本名称" />
            <TextBlock
                Grid.Column="1"
                Width="200"
                Padding="8,4"
                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                Text="时间区间" />
            <TextBlock
                Grid.Column="2"
                Width="88"
                Padding="8,4"
                HorizontalAlignment="Right"
                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                Text="状态" />
            <TextBlock
                Grid.Column="3"
                Padding="8,4"
                HorizontalAlignment="Right"
                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                Text="进度" />
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <controls:ListEmptyState
                    Margin="{StaticResource AloneMarginTop24}"
                    Title="暂无项目"
                    Description="请先创建项目，再在「版本」中维护发布计划。"
                    Glyph="&#xE8F1;"
                    IsPrimaryVisible="False"
                    Visibility="{x:Bind ViewModel.EmptyProjectsVisibility, Mode=OneWay}" />

                <controls:ListEmptyState
                    Margin="{StaticResource AloneMarginTop24}"
                    Title="请选择项目"
                    Description="请先在上方选择所属项目。"
                    Glyph="&#xE8F1;"
                    IsPrimaryVisible="False"
                    Visibility="{x:Bind ViewModel.SelectProjectVisibility, Mode=OneWay}" />

                <controls:ListEmptyState
                    Margin="{StaticResource AloneMarginTop24}"
                    Title="当前项目暂无版本计划"
                    Description="点击下方按钮创建版本，规划发布节奏与关联项。"
                    Footnote="从创建一个里程碑开始，掌控开发节奏。"
                    Glyph="&#xE8F1;"
                    IconFontSize="32"
                    IconBadgePadding="14,14,14,14"
                    PrimaryCommand="{x:Bind ViewModel.RequestNewReleaseUiCommand, Mode=OneWay}"
                    PrimaryLabel="新建版本"
                    Visibility="{x:Bind ViewModel.GlobalEmptyVisibility, Mode=OneWay}" />

                <controls:ListEmptyState
                    Margin="{StaticResource AloneMarginTop24}"
                    Title="无匹配版本"
                    Description="请调整筛选或搜索关键词。"
                    Glyph="&#xE8F1;"
                    IsPrimaryVisible="False"
                    Visibility="{x:Bind ViewModel.NoMatchVisibility, Mode=OneWay}" />

                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{x:Bind ViewModel.ListVisibility, Mode=OneWay}">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Releases, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ReleaseRowViewModel">
                                <Button
                                    Margin="0,0,0,8"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding ElementName=ReleasePageRoot, Path=ViewModel.SelectReleaseRowCommand}"
                                    CommandParameter="{x:Bind Mode=OneTime}"
                                    CornerRadius="{StaticResource DefaultCornerRadius}">
                                    <Border
                                        Padding="8"
                                        HorizontalAlignment="Stretch"
                                        Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                                        CornerRadius="{StaticResource DefaultCornerRadius}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="96" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneTitleSmTextBlockStyle}"
                                                Text="{x:Bind Name, Mode=OneTime}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                Text="{x:Bind StartAt, Mode=OneTime}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Margin="0,16,0,0"
                                                VerticalAlignment="Center"
                                                Opacity="0.85"
                                                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                Text="{x:Bind EndAt, Mode=OneTime}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                Text="{x:Bind Status, Mode=OneTime}" />
                                            <TextBlock
                                                Grid.Column="3"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                                Text="{x:Bind ProgressLabel, Mode=OneTime}" />
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border
                Grid.Column="1"
                Margin="{StaticResource AloneDetailPanelMargin}"
                Padding="16"
                Width="340"
                Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                CornerRadius="{StaticResource DefaultCornerRadius}"
                Visibility="{x:Bind ViewModel.DetailPanelVisibility, Mode=OneWay}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource AloneTitleLgTextBlockStyle}" Text="{x:Bind ViewModel.DetailTitle, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource AloneBodyMdTextBlockStyle}"
                        Text="{x:Bind ViewModel.DetailMeta, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="进度（PRD 6.5.2）" />
                    <TextBlock
                        Opacity="0.9"
                        Style="{StaticResource AloneBodyMdTextBlockStyle}"
                        Text="{x:Bind ViewModel.DetailProgressText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Command="{x:Bind ViewModel.RequestEditReleaseUiCommand, Mode=OneWay}"
                            Content="编辑"
                            IsEnabled="{x:Bind ViewModel.CanEditSelected, Mode=OneWay}"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                        <Button
                            Command="{x:Bind ViewModel.StartReleaseCommand, Mode=OneWay}"
                            Content="开始版本"
                            IsEnabled="{x:Bind ViewModel.CanStartSelected, Mode=OneWay}"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Command="{x:Bind ViewModel.MarkReleaseEndedCommand, Mode=OneWay}"
                            Content="标记已结束"
                            IsEnabled="{x:Bind ViewModel.CanFinishSelected, Mode=OneWay}"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                        <Button
                            Command="{x:Bind ViewModel.MarkReleaseCancelledCommand, Mode=OneWay}"
                            Content="标记已取消"
                            IsEnabled="{x:Bind ViewModel.CanFinishSelected, Mode=OneWay}"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Command="{x:Bind ViewModel.RequestAddRelationUiCommand, Mode=OneWay}"
                            Content="添加关联"
                            IsEnabled="{x:Bind ViewModel.CanAddRelation, Mode=OneWay}"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                        <Button
                            Command="{x:Bind ViewModel.ExportReleaseReportCommand, Mode=OneWay}"
                            Content="导出报告"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                    <Button
                        Click="GenerateGitChangelog_Click"
                        Content="从 Git 生成变更说明"
                        IsEnabled="{x:Bind ViewModel.CanShowGitChangelogButton, Mode=OneWay}"
                        Style="{StaticResource AloneSecondaryButtonStyle}" />
                    <Button
                        Click="DeleteRelease_Click"
                        Content="删除版本"
                        IsEnabled="{x:Bind ViewModel.CanDeleteSelected, Mode=OneWay}"
                        Style="{StaticResource AloneSecondaryButtonStyle}" />
                    <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="关联列表" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.DetailRelations, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ReleaseRelationItemViewModel">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Style="{StaticResource AloneBodyMdTextBlockStyle}" Text="{x:Bind TypeLabel, Mode=OneTime}" />
                                        <TextBlock
                                            Opacity="0.9"
                                            Style="{StaticResource AloneTitleSmTextBlockStyle}"
                                            Text="{x:Bind DisplayName, Mode=OneTime}" />
                                    </StackPanel>
                                    <Button
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Command="{Binding ElementName=ReleasePageRoot, Path=ViewModel.RemoveRelationCommand}"
                                        CommandParameter="{x:Bind Mode=OneTime}"
                                        Content="移除"
                                        Style="{StaticResource AloneSecondaryButtonStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button
                        Command="{x:Bind ViewModel.ClearReleaseSelectionCommand, Mode=OneWay}"
                        Content="关闭详情"
                        Style="{StaticResource AloneSecondaryButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
