<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PMTool.App.Views.Documents.DocumentListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Views.Documents"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:Name="DocPageRoot"
    x:DataType="local:DocumentListPage"
    Background="{ThemeResource AloneSurfaceBrush}"
    mc:Ignorable="d">
    <Grid Padding="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="316" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid
            Grid.Column="0"
            Margin="{StaticResource AloneMarginTop24}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,8"
                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                Text="文档树" />

            <Border
                Grid.Row="1"
                Background="{ThemeResource AloneSurfaceContainerLowBrush}"
                CornerRadius="{StaticResource DefaultCornerRadius}">
                <ListView
                    x:Name="DocList"
                    Padding="4"
                    ItemsSource="{x:Bind ViewModel.ListRows, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedListRow, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DocumentListRowViewModel">
                            <StackPanel Padding="12,8" Spacing="4">
                                <TextBlock
                                    FontSize="{x:Bind TitleFontSize, Mode=OneWay}"
                                    FontWeight="SemiBold"
                                    Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                    Text="{x:Bind PrimaryText, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"
                                    Visibility="{x:Bind SectionHeaderVisibility, Mode=OneWay}" />
                                <Border
                                    Padding="6,6"
                                    Background="{x:Bind IsSearchHighlight, Converter={StaticResource SearchRowBackgroundConverter}, Mode=OneWay}"
                                    CornerRadius="{StaticResource DefaultCornerRadius}"
                                    Visibility="{x:Bind DocumentRowVisibility, Mode=OneWay}">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            MaxLines="2"
                                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                            Text="{x:Bind PrimaryText, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            MaxLines="2"
                                            Style="{StaticResource AloneModuleMetaTextBlockStyle}"
                                            Text="{x:Bind Subtitle, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="WrapWholeWords"
                                            Visibility="{x:Bind SubtitleVisibility, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>

        <Grid
            Grid.Column="2"
            Margin="{StaticResource AloneMarginTop24}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Margin="0,0,0,12"
                Padding="{StaticResource AloneModuleChromePadding}"
                Background="{ThemeResource AloneSurfaceContainerLowBrush}"
                CornerRadius="{StaticResource DefaultCornerRadius}"
                Visibility="{x:Bind ViewModel.ErrorBannerVisibility, Mode=OneWay}">
                <TextBlock
                    Foreground="{ThemeResource AloneErrorBrush}"
                    Text="{x:Bind ViewModel.ErrorBanner, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </Border>

            <Border
                Grid.Row="1"
                Margin="0,0,0,12"
                Padding="{StaticResource AloneModuleChromePadding}"
                Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                CornerRadius="{StaticResource DefaultCornerRadius}"
                Visibility="{x:Bind ViewModel.EditorPanelVisibility, Mode=OneWay}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        Background="{ThemeResource AloneSurfaceContainerHighestBrush}"
                        BorderThickness="0"
                        CornerRadius="{StaticResource DefaultCornerRadius}"
                        Header="标题"
                        PlaceholderText="文档名称"
                        Style="{StaticResource AloneFormTextBoxStyle}"
                        Text="{x:Bind ViewModel.EditorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel
                        Grid.Row="1"
                        Margin="0,0,0,12"
                        Spacing="6">
                        <ToggleSwitch
                            Header="在「代码片段」中显示"
                            IsOn="{x:Bind ViewModel.IsCodeSnippetEditor, Mode=TwoWay}"
                            Style="{StaticResource AloneFormToggleSwitchStyle}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="{StaticResource LabelMdFontSize}"
                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                            Text="开启后该文档会出现在侧栏「代码片段」列表，用于归类备忘；正文仍为 Markdown，显示方式不变。若需指定语法高亮语言，请在该页编辑对应片段。"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="12"
                            VerticalAlignment="Center">
                            <Button
                                VerticalAlignment="Center"
                                Command="{x:Bind ViewModel.RequestExportHtmlUiCommand, Mode=OneWay}"
                                Content="导出 HTML"
                                Style="{StaticResource AlonePrimaryButtonStyle}" />
                            <Button
                                VerticalAlignment="Center"
                                Click="RenameDocument_Click"
                                Content="重命名"
                                Style="{StaticResource AloneSecondaryButtonStyle}" />
                            <Button
                                VerticalAlignment="Center"
                                Click="DeleteDocument_Click"
                                Content="删除"
                                Style="{StaticResource AloneSecondaryButtonStyle}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Spacing="12"
                            VerticalAlignment="Center">
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                FontSize="{StaticResource LabelMdFontSize}"
                                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                Text="{x:Bind ViewModel.DocumentSaveStatusText, Mode=OneWay}" />
                            <HyperlinkButton
                                VerticalAlignment="Center"
                                Command="{x:Bind ViewModel.SaveCurrentCommand, Mode=OneWay}"
                                Content="立即保存"
                                ToolTipService.ToolTip="立即保存到本地（默认快捷键 Ctrl+S，可在设置中修改）" />
                        </StackPanel>
                    </Grid>
                    <TextBlock
                        Grid.Row="3"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="{StaticResource LabelMdFontSize}"
                        Style="{StaticResource AloneBodyMdTextBlockStyle}"
                        Text="支持 Markdown 语法。支持拖拽/粘贴图片（最大 50MB）。" />
                </Grid>
            </Border>

            <Border
                Grid.Row="2"
                Padding="{StaticResource AloneModuleChromePadding}"
                Background="{ThemeResource AloneSurfaceContainerLowBrush}"
                CornerRadius="{StaticResource DefaultCornerRadius}"
                Visibility="{x:Bind ViewModel.EditorPanelVisibility, Mode=OneWay}">
                <TextBox
                    x:Name="MarkdownEditor"
                    AcceptsReturn="True"
                    FontFamily="Cascadia Mono, Consolas, monospace"
                    PlaceholderText="在此编辑 Markdown…"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    Text="{x:Bind ViewModel.MarkdownBody, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Grid>
</Page>
