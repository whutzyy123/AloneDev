<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PMTool.App.Views.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:DataType="local:SettingsPage"
    Background="{ThemeResource AloneSurfaceBrush}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer
            Grid.Row="0"
            Padding="0"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                MaxWidth="920"
                Padding="{StaticResource AloneFormPageScrollBottomPadding}"
                HorizontalAlignment="Stretch"
                Spacing="{StaticResource AloneFormSectionSpacing}">
                <InfoBar
                    IsClosable="False"
                    IsOpen="{x:Bind ViewModel.SuccessVisible, Mode=OneWay}"
                    Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                    Severity="Success" />

                <TextBlock Style="{StaticResource AloneHeadlineSmTextBlockStyle}" Text="系统设置" />

                <TextBlock
                    Foreground="{ThemeResource AloneWarningBrush}"
                    Style="{StaticResource AloneBodyMdTextBlockStyle}"
                    Text="{x:Bind ViewModel.ErrorBanner, Mode=OneWay}"
                    TextWrapping="WrapWholeWords"
                    Visibility="{x:Bind ViewModel.ErrorBanner, Mode=OneWay, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" />

                <Border Style="{StaticResource AloneFormSectionCardStyle}">
                    <StackPanel Spacing="{StaticResource AloneSpace12}">
                        <TextBlock Style="{StaticResource AloneFormSectionTitleStyle}" Text="主题" />
                        <TextBlock
                            Style="{StaticResource AloneFormSectionDescriptionStyle}"
                            Text="当前选择会立即写入 config 并应用。" />
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace8}">
                            <Button
                                Command="{x:Bind ViewModel.SelectThemeCommand}"
                                CommandParameter="{x:Bind ThemeLight, Mode=OneWay}"
                                Content="浅色"
                                Style="{StaticResource AloneSecondaryButtonStyle}" />
                            <Button
                                Command="{x:Bind ViewModel.SelectThemeCommand}"
                                CommandParameter="{x:Bind ThemeDark, Mode=OneWay}"
                                Content="深色"
                                Style="{StaticResource AloneSecondaryButtonStyle}" />
                            <Button
                                Command="{x:Bind ViewModel.SelectThemeCommand}"
                                CommandParameter="{x:Bind ThemeFollowSystem, Mode=OneWay}"
                                Content="跟随系统"
                                Style="{StaticResource AloneSecondaryButtonStyle}" />
                        </StackPanel>
                        <Grid
                            MaxWidth="480"
                            HorizontalAlignment="Left"
                            ColumnSpacing="{StaticResource AloneSpace12}"
                            ColumnDefinitions="*,*">
                            <Border
                                Grid.Column="0"
                                Padding="{StaticResource AlonePadding12}"
                                Background="{ThemeResource AloneSurfaceContainerHighestBrush}"
                                CornerRadius="{StaticResource DefaultCornerRadius}">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource AloneTitleSmTextBlockStyle}" Text="浅色示意" />
                                    <Border
                                        Height="40"
                                        CornerRadius="4"
                                        Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Opacity="0.15" />
                                </StackPanel>
                            </Border>
                            <Border
                                Grid.Column="1"
                                Padding="{StaticResource AlonePadding12}"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="{StaticResource DefaultCornerRadius}">
                                <StackPanel Spacing="6">
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Style="{StaticResource AloneTitleSmTextBlockStyle}"
                                        Text="深色示意" />
                                    <Border
                                        Height="40"
                                        CornerRadius="4"
                                        Background="{ThemeResource TextFillColorSecondaryBrush}"
                                        Opacity="0.3" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AloneFormSectionCardStyle}">
                    <StackPanel Spacing="{StaticResource AloneSpace12}">
                        <TextBlock Style="{StaticResource AloneFormSectionTitleStyle}" Text="数据存储路径" />
                        <TextBlock
                            Style="{StaticResource AloneFormSectionDescriptionStyle}"
                            Text="显示当前生效根目录与 config 中记录的 DataPath；迁移须选择空文件夹，完成后需保持路径与权限可用。" />
                        <TextBlock Style="{StaticResource AloneBodyMdTextBlockStyle}" Text="当前生效根：" />
                        <TextBlock
                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                            Text="{x:Bind ViewModel.DataRootPathDisplay, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource AloneBodyMdTextBlockStyle}" Text="config.json 中的 DataPath 记录：" />
                        <TextBlock
                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                            Text="{x:Bind ViewModel.ConfigDataPathNote, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <StackPanel Spacing="{StaticResource AloneSpace8}">
                            <TextBox
                                Header="迁移目标（须为空文件夹）"
                                PlaceholderText="例如 D:\PMData"
                                Style="{StaticResource AloneFormTextBoxStyle}"
                                Text="{x:Bind ViewModel.MigrationTargetPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace12}">
                                <Button Click="PickMigrationFolder_Click" Content="浏览文件夹…" Style="{StaticResource AloneSecondaryButtonStyle}" />
                                <Button
                                    Command="{x:Bind ViewModel.RunMigrationCommand}"
                                    Content="开始迁移"
                                    IsEnabled="{x:Bind ViewModel.IsMigrating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                    Style="{StaticResource AloneSecondaryButtonStyle}" />
                            </StackPanel>
                            <ProgressBar
                                Maximum="100"
                                Minimum="0"
                                Value="{x:Bind ViewModel.MigrationPercent, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.IsMigrating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <TextBlock Style="{StaticResource AloneBodyMdTextBlockStyle}" Text="{x:Bind ViewModel.MigrationStatusText, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AloneFormSectionCardStyle}">
                    <StackPanel Spacing="{StaticResource AloneSpace12}">
                        <TextBlock Style="{StaticResource AloneFormSectionTitleStyle}" Text="账号" />
                        <TextBlock
                            Style="{StaticResource AloneFormSectionDescriptionStyle}"
                            Text="侧栏顶部可切换或创建账号；本机账户名即隔离键，不包含密码校验。" />
                        <Button
                            HorizontalAlignment="Left"
                            Command="{x:Bind ViewModel.OpenDataManagementCommand}"
                            Content="打开数据管理…"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AloneFormSectionCardStyle}">
                    <StackPanel Spacing="{StaticResource AloneSpace12}">
                        <TextBlock Style="{StaticResource AloneFormSectionTitleStyle}" Text="快捷键" />
                        <TextBlock
                            Style="{StaticResource AloneFormSectionDescriptionStyle}"
                            Text="点击下方「保存设置」后生效；全局搜索固定为 Ctrl+K。" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.ShortcutRows, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SettingsShortcutRowViewModel">
                                    <Grid
                                        Padding="0,8,0,8"
                                        ColumnSpacing="{StaticResource AloneSpace12}"
                                        ColumnDefinitions="200,*">
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                                            Text="{x:Bind Label, Mode=OneWay}" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="{StaticResource AloneSpace8}">
                                            <TextBox
                                                Width="220"
                                                Style="{StaticResource AloneFormTextBoxStyle}"
                                                IsReadOnly="{x:Bind IsReadOnlyBinding, Mode=OneWay}"
                                                Text="{x:Bind BindingDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button
                                                VerticalAlignment="Center"
                                                Click="RecordShortcut_Click"
                                                Content="录制…"
                                                IsEnabled="{x:Bind IsReadOnlyBinding, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                                Style="{StaticResource AloneSecondaryButtonStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Style="{StaticResource AloneFormPageStickyFooterStyle}">
            <StackPanel
                MaxWidth="920"
                HorizontalAlignment="Stretch"
                Orientation="Horizontal"
                Spacing="{StaticResource AloneSpace12}">
                <Button
                    Command="{x:Bind ViewModel.SaveShortcutsCommand}"
                    Content="保存设置"
                    Style="{StaticResource AccentButtonStyle}" />
                <Button Command="{x:Bind ViewModel.ResetShortcutsToDefaultsCommand}" Content="恢复默认快捷键" Style="{StaticResource AloneSecondaryButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
