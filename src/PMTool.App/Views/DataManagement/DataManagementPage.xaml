<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PMTool.App.Views.DataManagement.DataManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PMTool.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Views.DataManagement"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:DataType="local:DataManagementPage"
    Background="{ThemeResource AloneSurfaceBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="DataManagementBackupRowTemplate" x:DataType="vm:DataManagementBackupRowViewModel">
            <Border
                Margin="0,0,0,{StaticResource AloneListCardSpacing}"
                Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                CornerRadius="{StaticResource CornerRadiusLarge}"
                Style="{StaticResource AloneElevatedCardBorderStyle}">
                <Grid Padding="{StaticResource AloneListCardPadding}" ColumnSpacing="{StaticResource AloneSpace16}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Grid.Column="0"
                        Width="52"
                        Height="52"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="{ThemeResource AloneSurfaceContainerHighBrush}"
                        CornerRadius="{StaticResource CornerRadiusSmall}">
                        <Viewbox
                            Width="26"
                            Height="26"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <SymbolIcon Foreground="{ThemeResource AlonePrimaryBrush}" Symbol="SaveLocal" />
                        </Viewbox>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="{StaticResource AloneSpace8}">
                        <TextBlock
                            MaxLines="2"
                            Style="{StaticResource AloneListCardTitleStyle}"
                            Text="{x:Bind FileName, Mode=OneTime}"
                            TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource AloneListCardMetaStyle}" Text="{x:Bind SizeDisplay, Mode=OneTime}" />
                        <TextBlock Style="{StaticResource AloneListCardMetaStyle}" Text="{x:Bind TimeDisplay, Mode=OneTime}" />
                    </StackPanel>
                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Spacing="{StaticResource AloneSpace8}">
                        <Button
                            Click="OpenBackupFolder_Click"
                            Content="打开目录"
                            Style="{StaticResource AloneSecondaryButtonStyle}"
                            Tag="{x:Bind AbsolutePath, Mode=OneTime}" />
                        <Button
                            Click="DeleteBackupRow_Click"
                            Content="删除"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>
    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar
            Grid.Row="0"
            Margin="{StaticResource AloneMarginBottom12}"
            IsClosable="True"
            IsOpen="{x:Bind ViewModel.ErrorBanner, Mode=OneWay, Converter={StaticResource StringNotEmptyToBoolConverter}}"
            Message="{x:Bind ViewModel.ErrorBanner, Mode=OneWay}"
            Severity="Error"
            Closing="ErrorInfoBar_Closing" />

        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                MaxWidth="920"
                Padding="{StaticResource AloneFormPageScrollBottomPadding}"
                HorizontalAlignment="Stretch"
                Spacing="{StaticResource AloneFormSectionSpacing}">
                <TextBlock
                    Opacity="0.9"
                    Style="{StaticResource AloneBodyMdTextBlockStyle}"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />

                <!-- 当前数据库 -->
                <Border
                    Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                    Style="{StaticResource AloneElevatedCardBorderStyle}">
                    <StackPanel Padding="{StaticResource AlonePadding16}" Spacing="{StaticResource AloneSpace16}">
                        <TextBlock Style="{StaticResource AloneFormSectionTitleStyle}" Text="当前数据库" />
                        <TextBlock
                            Style="{StaticResource AloneFormSectionDescriptionStyle}"
                            Text="当前账户正在使用的 SQLite 路径与体量（只读）。" />
                        <TextBlock
                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                            Text="{x:Bind ViewModel.DatabasePath, Mode=OneWay}"
                            TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace16}">
                            <TextBlock Style="{StaticResource AloneBodyMdTextBlockStyle}" Text="{x:Bind ViewModel.DatabaseSizeText, Mode=OneWay}" />
                            <TextBlock Style="{StaticResource AloneBodyMdTextBlockStyle}" Text="{x:Bind ViewModel.DatabaseModifiedText, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 备份 -->
                <Border
                    Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                    Style="{StaticResource AloneElevatedCardBorderStyle}">
                    <StackPanel Padding="{StaticResource AlonePadding16}" Spacing="{StaticResource AloneSpace16}">
                        <TextBlock Style="{StaticResource AloneFormSectionTitleStyle}" Text="备份" />
                        <TextBlock
                            Style="{StaticResource AloneFormSectionDescriptionStyle}"
                            Text="手动或按策略将数据库复制到本地备份目录；删除备份不可恢复。" />
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace16}">
                            <Button
                                Click="ManualBackup_Click"
                                Content="手动备份…"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                            <ProgressRing
                                Width="28"
                                Height="28"
                                IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ToggleSwitch
                                x:Name="AutoBackupSwitch"
                                Grid.Row="0"
                                Header="自动备份"
                                IsOn="{x:Bind ViewModel.AutoBackupEnabled, Mode=TwoWay}"
                                Style="{StaticResource AloneFormToggleSwitchStyle}" />
                            <NumberBox
                                Grid.Row="1"
                                Width="200"
                                Header="保留备份数量"
                                Maximum="99"
                                Minimum="1"
                                SpinButtonPlacementMode="Inline"
                                Style="{StaticResource AloneFormNumberBoxStyle}"
                                Value="{x:Bind ViewModel.RetentionCount, Mode=TwoWay}" />
                            <NumberBox
                                Grid.Row="2"
                                Width="240"
                                Header="最大备份间隔（小时，启动补备）"
                                Maximum="8760"
                                Minimum="1"
                                SpinButtonPlacementMode="Inline"
                                Style="{StaticResource AloneFormNumberBoxStyle}"
                                Value="{x:Bind ViewModel.MaxBackupIntervalHours, Mode=TwoWay}" />
                            <TextBox
                                Grid.Row="3"
                                Header="备份子目录（相对账户目录）"
                                PlaceholderText="Backup"
                                Style="{StaticResource AloneFormTextBoxStyle}"
                                Text="{x:Bind ViewModel.BackupDirectoryRelative, Mode=TwoWay}" />
                        </Grid>
                        <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="备份列表" />
                        <controls:ListEmptyState
                            Title="暂无备份文件"
                            Description="使用「手动备份」在选定目录生成 .db 快照，或开启自动备份。"
                            Glyph="&#xE74E;"
                            IsPrimaryVisible="False"
                            Visibility="{x:Bind ViewModel.ShowBackupListEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <ItemsControl
                            ItemTemplate="{StaticResource DataManagementBackupRowTemplate}"
                            ItemsSource="{x:Bind ViewModel.BackupRows, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.ShowBackupListHasItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

                <!-- 恢复 -->
                <Border
                    Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                    Style="{StaticResource AloneElevatedCardBorderStyle}">
                    <StackPanel Padding="{StaticResource AlonePadding16}" Spacing="{StaticResource AloneSpace16}">
                        <TextBlock Style="{StaticResource AloneFormSectionTitleStyle}" Text="恢复" />
                        <TextBlock
                            Style="{StaticResource AloneFormSectionDescriptionStyle}"
                            Text="从本地 .db 备份还原；恢复前会自动再备份当前库，完成后请重启应用。" />
                        <Button Click="PickRestoreFile_Click" Content="选择备份文件并恢复…" />
                    </StackPanel>
                </Border>

                <!-- 导出 -->
                <Border
                    Background="{ThemeResource AloneSurfaceContainerLowestBrush}"
                    Style="{StaticResource AloneElevatedCardBorderStyle}">
                    <StackPanel Padding="{StaticResource AlonePadding16}" Spacing="{StaticResource AloneSpace16}">
                        <TextBlock Style="{StaticResource AloneFormSectionTitleStyle}" Text="导出" />
                        <TextBlock
                            Style="{StaticResource AloneFormSectionDescriptionStyle}"
                            Text="将所选模块导出为本地 CSV 或 Excel（仅本机文件，无网络上传）。" />
                        <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="模块（多选）" />
                        <StackPanel Spacing="{StaticResource AloneSpace8}">
                            <CheckBox Content="项目" IsChecked="{x:Bind ViewModel.ExportProjects, Mode=TwoWay}" />
                            <CheckBox Content="模块" IsChecked="{x:Bind ViewModel.ExportFeatures, Mode=TwoWay}" />
                            <CheckBox Content="任务" IsChecked="{x:Bind ViewModel.ExportTasks, Mode=TwoWay}" />
                            <CheckBox Content="版本" IsChecked="{x:Bind ViewModel.ExportReleases, Mode=TwoWay}" />
                            <CheckBox Content="文档" IsChecked="{x:Bind ViewModel.ExportDocuments, Mode=TwoWay}" />
                            <CheckBox Content="灵感池" IsChecked="{x:Bind ViewModel.ExportIdeas, Mode=TwoWay}" />
                        </StackPanel>
                        <CheckBox Content="导出为 CSV（否则为 Excel .xlsx）" IsChecked="{x:Bind ViewModel.ExportUseCsv, Mode=TwoWay}" />
                        <Button
                            Click="ExportPickFolder_Click"
                            Content="选择导出目录并开始导出…"
                            IsEnabled="{x:Bind ViewModel.CanExport, Mode=OneWay}" />
                        <ProgressBar
                            Maximum="100"
                            Visibility="{x:Bind ViewModel.ShowExportProgress, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            Value="{x:Bind ViewModel.ExportProgress, Mode=OneWay}" />
                        <TextBlock
                            Style="{StaticResource AloneBodySecondaryTextBlockStyle}"
                            Text="{x:Bind ViewModel.ExportProgressText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
