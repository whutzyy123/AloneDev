<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PMTool.App.Views.Snippets.SnippetListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Views.Snippets"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PMTool.Core.Models"
    x:Name="SnippetPageRoot"
    x:DataType="local:SnippetListPage"
    Background="{ThemeResource AloneSurfaceBrush}"
    mc:Ignorable="d">
    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="{StaticResource AloneMarginTop24Bottom12}"
            Padding="{StaticResource AloneModuleChromePadding}"
            Background="{ThemeResource AloneSurfaceContainerLowBrush}"
            CornerRadius="{StaticResource DefaultCornerRadius}"
            Visibility="{x:Bind ViewModel.ErrorBannerVisibility, Mode=OneWay}">
            <TextBlock
                Foreground="{ThemeResource AloneErrorBrush}"
                Text="{x:Bind ViewModel.ErrorBanner, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />
        </Border>

        <Grid Grid.Row="1" Padding="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="8">
                    <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="列表范围" />
                    <ComboBox
                        Header="关联项目筛选"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource AloneComboBoxStyle}"
                        DisplayMemberPath="Name"
                        SelectedValuePath="Id"
                        ItemsSource="{x:Bind ViewModel.ProjectOptions, Mode=OneWay}"
                        SelectedValue="{x:Bind ViewModel.ListFilterProjectId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{x:Bind ViewModel.ListFilterProjectVisibility, Mode=OneWay}" />
                </StackPanel>

                <TextBlock
                    Grid.Row="1"
                    Margin="0,12,0,8"
                    Style="{StaticResource AloneLabelMdTextBlockStyle}"
                    Text="片段" />

                <ListView
                    x:Name="SnippetList"
                    Grid.Row="2"
                    Background="{ThemeResource AloneSurfaceContainerLowBrush}"
                    CornerRadius="{StaticResource DefaultCornerRadius}"
                    ItemsSource="{x:Bind ViewModel.Snippets, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedSnippet, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:PmDocument">
                            <StackPanel Padding="8" Spacing="4">
                                <TextBlock Style="{StaticResource AloneBodyMdTextBlockStyle}" Text="{x:Bind Name, Mode=OneTime}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border
                                        Padding="6,2"
                                        Background="{ThemeResource AloneSurfaceContainerHighBrush}"
                                        CornerRadius="{StaticResource CornerRadiusSmall}">
                                        <TextBlock
                                            FontSize="11"
                                            Opacity="0.9"
                                            Text="{x:Bind SnippetLanguage, Mode=OneTime, TargetNullValue=plaintext}" />
                                    </Border>
                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.7"
                                        Text="{x:Bind UpdatedAt, Mode=OneTime}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid Grid.Column="1" MinWidth="400">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,0,12"
                    Spacing="12"
                    Visibility="{x:Bind ViewModel.EditorPanelVisibility, Mode=OneWay}">
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox
                            Grid.Row="0"
                            Grid.Column="0"
                            Header="名称"
                            Text="{x:Bind ViewModel.EditorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ComboBox
                            Grid.Row="0"
                            Grid.Column="1"
                            Header="高亮语言"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AloneComboBoxStyle}"
                            ItemsSource="{x:Bind ViewModel.LanguageOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.EditorLanguage, Mode=TwoWay}" />
                        <ComboBox
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Header="关联范围"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AloneComboBoxStyle}"
                            SelectedItem="{x:Bind ViewModel.EditorRelateType, Mode=TwoWay}">
                            <ComboBox.Items>
                                <x:String>全局文档</x:String>
                                <x:String>项目</x:String>
                            </ComboBox.Items>
                        </ComboBox>
                        <ComboBox
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AloneComboBoxStyle}"
                            Header="所属项目"
                            DisplayMemberPath="Name"
                            SelectedValuePath="Id"
                            ItemsSource="{x:Bind ViewModel.ProjectOptions, Mode=OneWay}"
                            SelectedValue="{x:Bind ViewModel.EditorProjectId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{x:Bind ViewModel.EditorProjectVisibility, Mode=OneWay}" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Command="{x:Bind ViewModel.SaveCommand}"
                            Content="保存"
                            Style="{StaticResource AlonePrimaryButtonStyle}" />
                        <Button
                            Command="{x:Bind ViewModel.CopySourceCommand}"
                            Content="复制源码"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid
                        ColumnSpacing="12"
                        Visibility="{x:Bind ViewModel.EditorPanelVisibility, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="SourceEditor"
                            Grid.Column="0"
                            AcceptsReturn="True"
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            Header="源码（纯文本）"
                            IsSpellCheckEnabled="False"
                            Text="{x:Bind ViewModel.SourceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="NoWrap" />
                        <Border
                            Grid.Column="1"
                            Background="{ThemeResource AloneCodePreviewHostBrush}"
                            CornerRadius="{StaticResource DefaultCornerRadius}">
                            <controls:WebView2 x:Name="PreviewWeb" />
                        </Border>
                    </Grid>

                    <TextBlock
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Style="{StaticResource AloneBodyMdTextBlockStyle}"
                        Text="请新建片段或从左侧选择一项。"
                        Visibility="{x:Bind ViewModel.EmptyHintVisibility, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
