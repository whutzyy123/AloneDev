<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PMTool.App.Controls.GlobalSearchPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PMTool.App.ViewModels"
    x:Name="SearchPanelRoot"
    x:DataType="local:GlobalSearchPanel"
    Padding="0"
    mc:Ignorable="d">
    <Border
        x:Name="FlyoutRootBorder"
        MaxHeight="520"
        Padding="8"
        HorizontalAlignment="Stretch"
        Background="Transparent"
        CornerRadius="{StaticResource DefaultCornerRadius}">
        <Grid RowSpacing="{StaticResource AloneSpace8}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Spacing="{StaticResource AloneSpace8}">
                <Border
                    Padding="10,6,10,6"
                    Background="{ThemeResource AloneSurfaceContainerHighBrush}"
                    CornerRadius="{StaticResource DefaultCornerRadius}"
                    Visibility="{x:Bind ViewModel.HasScopeTag, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AloneSpace8}">
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource AloneBodyMdTextBlockStyle}"
                            Text="{x:Bind ViewModel.ScopeTagText, Mode=OneWay}" />
                        <Button
                            Padding="6,2,6,2"
                            Command="{x:Bind ViewModel.ClearScopeTagCommand, Mode=OneWay}"
                            Content="全库"
                            Style="{StaticResource AloneSecondaryButtonStyle}" />
                    </StackPanel>
                </Border>
                <TextBlock Style="{StaticResource AloneCaptionTextBlockStyle}" Text="搜索范围（默认当前模块，可切换）" />
                <StackPanel Spacing="4">
                    <CheckBox Content="项目" IsChecked="{x:Bind ViewModel.ScopeProjects, Mode=TwoWay}" />
                    <CheckBox Content="模块" IsChecked="{x:Bind ViewModel.ScopeFeatures, Mode=TwoWay}" />
                    <CheckBox Content="任务" IsChecked="{x:Bind ViewModel.ScopeTasks, Mode=TwoWay}" />
                    <CheckBox Content="文档" IsChecked="{x:Bind ViewModel.ScopeDocuments, Mode=TwoWay}" />
                    <CheckBox Content="灵感" IsChecked="{x:Bind ViewModel.ScopeIdeas, Mode=TwoWay}" />
                </StackPanel>
            </StackPanel>
            <TextBlock
                Grid.Row="1"
                Foreground="{ThemeResource AloneWarningBrush}"
                Style="{StaticResource AloneBodyMdTextBlockStyle}"
                Text="{x:Bind ViewModel.FilterHint, Mode=OneWay}"
                TextWrapping="WrapWholeWords"
                Visibility="{x:Bind ViewModel.FilterHint, Mode=OneWay, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" />
            <ScrollViewer
                Grid.Row="2"
                MaxHeight="280"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled">
                <ItemsControl ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:GlobalSearchGroupViewModel">
                            <StackPanel Margin="0,0,0,8" Spacing="4">
                                <TextBlock Style="{StaticResource AloneLabelMdTextBlockStyle}" Text="{x:Bind Title, Mode=OneWay}" />
                                <Button
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{x:Bind ToggleExpandCommand, Mode=OneWay}"
                                    Content="{x:Bind ExpandToggleText, Mode=OneWay}"
                                    CornerRadius="{StaticResource DefaultCornerRadius}"
                                    Visibility="{x:Bind ShowMoreChevron, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{x:Bind DisplayedHits, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:GlobalSearchHitRowViewModel">
                                            <Button
                                                Margin="0,0,0,4"
                                                Padding="8,6"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Background="{x:Bind IsKeyboardHighlighted, Converter={StaticResource SearchRowBackgroundConverter}, Mode=OneWay}"
                                                Click="HitResult_Click"
                                                GotFocus="HitRow_GotFocus"
                                                Style="{StaticResource AloneGlobalSearchHitButtonStyle}">
                                                <StackPanel Spacing="2">
                                                    <TextBlock
                                                        MaxLines="1"
                                                        Style="{StaticResource AloneTitleSmTextBlockStyle}"
                                                        Text="{x:Bind Title, Mode=OneWay}"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <local:HighlightedSnippetBlock
                                                        Highlight="{x:Bind HighlightNeedle, Mode=OneWay}"
                                                        Text="{x:Bind Snippet, Mode=OneWay}" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <StackPanel
                Grid.Row="3"
                Orientation="Horizontal"
                Spacing="{StaticResource AloneSpace8}"
                VerticalAlignment="Center">
                <ProgressRing
                    Width="22"
                    Height="22"
                    VerticalAlignment="Center"
                    IsActive="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsSearching, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource AloneBodySecondaryTextBlockStyle}"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
