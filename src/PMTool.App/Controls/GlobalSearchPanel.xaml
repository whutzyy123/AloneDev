<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PMTool.App.Controls.GlobalSearchPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PMTool.App.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Border
        Padding="16"
        MinWidth="360"
        Background="{StaticResource AloneSurfaceContainerLowestBrush}"
        CornerRadius="{StaticResource DefaultCornerRadius}">
        <StackPanel Spacing="12">
            <TextBlock Style="{StaticResource AloneTitleSmTextBlockStyle}" Text="全局搜索" />
            <AutoSuggestBox x:Name="QueryBox" PlaceholderText="输入关键词（500ms 防抖后查询将接入）" />
            <TextBlock
                Opacity="0.7"
                Style="{StaticResource AloneLabelMdTextBlockStyle}"
                Text="暂未连接数据库；仅 UI 骨架。" />
        </StackPanel>
    </Border>
</UserControl>
