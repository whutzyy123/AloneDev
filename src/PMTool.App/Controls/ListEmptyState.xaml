<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PMTool.App.Controls.ListEmptyState"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PMTool.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="EmptyRoot"
    x:DataType="local:ListEmptyState"
    mc:Ignorable="d">
    <StackPanel
        MaxWidth="440"
        HorizontalAlignment="Center"
        Spacing="{StaticResource AloneSpace16}">
        <Border
            Padding="22"
            HorizontalAlignment="Center"
            Background="{ThemeResource AloneSurfaceContainerHighBrush}"
            CornerRadius="24">
            <FontIcon
                HorizontalAlignment="Center"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                FontSize="44"
                Foreground="{ThemeResource AlonePrimaryBrush}"
                Glyph="{x:Bind Glyph, Mode=OneWay}" />
        </Border>
        <TextBlock
            HorizontalAlignment="Center"
            Style="{StaticResource AloneHeadlineSmTextBlockStyle}"
            Text="{x:Bind Title, Mode=OneWay}"
            TextAlignment="Center"
            TextWrapping="WrapWholeWords" />
        <TextBlock
            HorizontalAlignment="Center"
            Opacity="0.92"
            Style="{StaticResource AloneBodyMdTextBlockStyle}"
            Text="{x:Bind Description, Mode=OneWay}"
            TextAlignment="Center"
            TextWrapping="WrapWholeWords" />
        <Button
            HorizontalAlignment="Center"
            Command="{x:Bind PrimaryCommand, Mode=OneWay}"
            Content="{x:Bind PrimaryLabel, Mode=OneWay}"
            Style="{StaticResource AlonePrimaryButtonStyle}"
            Visibility="{x:Bind IsPrimaryVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
    </StackPanel>
</UserControl>
