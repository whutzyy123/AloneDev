<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="PMTool.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:conv="using:PMTool.App.Converters"
    xmlns:local="using:PMTool.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <conv:SearchRowBackgroundConverter x:Key="SearchRowBackgroundConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter" />
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
            <conv:StringNotEmptyToBoolConverter x:Key="StringNotEmptyToBoolConverter" />
            <conv:ProjectStatusChipBrushConverter x:Key="ProjectStatusChipBrushConverter" />
            <conv:TaskTypeAccentBrushConverter x:Key="TaskTypeAccentBrushConverter" />
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Spacing.xaml" />
                <ResourceDictionary Source="Themes/TypeRamp.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
                <ResourceDictionary Source="Themes/Cards.xaml" />
                <ResourceDictionary Source="Themes/Elevation.xaml" />
                <ResourceDictionary Source="Themes/Dialogs.xaml" />
                <ResourceDictionary Source="Themes/FormSections.xaml" />
                <ResourceDictionary Source="Themes/GlobalSearch.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
